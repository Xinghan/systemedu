# scripts/deploy.env — 部署信息单一来源 (所有部署脚本 source 它)
# 换服务器只改这里。

# 生产服务器
SERVER_HOST=47.106.220.119
SERVER_USER=root
# SSH: 该服务器走密码登录, 需强制密码认证 (否则先试 publickey 失败)
SSH_OPTS="-o StrictHostKeyChecking=no -o PreferredAuthentications=password -o PubkeyAuthentication=no"
# 密码不写进文件 — 运行时经 SSHPASS 环境变量传入: export SSHPASS='...'; sshpass -e ssh ...

# 服务器路径
REPO_ROOT=/opt/systemedu

# 服务端口
STUDENT_BACKEND_PORT=18820
STUDENT_WEB_PORT=4000
LIBRARY_PORT=18821
ADMIN_PORT=18822          # 学生管理后台 (独立只读服务, /sysadmin)

# 对外访问 — 域名 systeme.xin 已配 HTTPS (阿里云/DigiCert DV 证书, 到期 2026-12-13)
PUBLIC_URL=https://systeme.xin

# SSL: 域名 + 服务器证书路径。SSL_DOMAIN 留空则 nginx 退回纯 HTTP (新服务器无证书时)。
# 证书文件 (systeme.xin.pem / systeme.xin.key) 由人工上传到 SSL_CERT_DIR, 不进 git。
# 注意: 大陆 ICP 备案未完成时, 阿里云会在网络层拦截域名的 80 端口 (返回 Non-compliance
# ICP Filing 页), 导致 HTTP->HTTPS 跳转到不了 nginx; 443 不受影响。备案通过后自动解除。
SSL_DOMAIN=systeme.xin
SSL_DOMAIN_ALT=www.systeme.xin
SSL_CERT_DIR=/etc/nginx/ssl

# 部署的课程清单 (slug, 空格分隔)。部署时从 COURSE_SRC 最新源现打包上传 + import + publish。
# COURSE_SRC 默认 $HOME/Dev/systemeduidea/projects_data, 可经 env 覆盖。
# 加新课程: 在此追加 slug (源目录须存在且 manifest.json 校验通过)。
COURSE_SLUGS="eeg-minecraft-bci purpleair-airquality-node mars-analog-rover ai-ant-ethologist satellite-archaeology molecule-monster-hunter"
