        "hint": "通常使用同步辐射或旋转阳极X射线管"
      },
      "monochromator": {
        "label_zh": "单色器",
        "label_en": "Monochromator",
        "desc_brief": "筛选特定波长X射线",
        "hint": "确保入射X射线具有单一波长，提高衍射质量"
      },
      "sample_holder": {
        "label_zh": "样品架",
        "label_en": "Sample Holder",
        "desc_brief": "固定蛋白质晶体",
        "hint": "通常在低温下保存晶体以减少辐射损伤"
      },
      "detector": {
        "label_zh": "探测器",
        "label_en": "Detector",
        "desc_brief": "记录衍射图案",
        "hint": "现代实验多用像素阵列探测器捕捉衍射点"
      },
      "beam_stop": {
        "label_zh": "光束挡板",
        "label_en": "Beam Stop",
        "desc_brief": "阻挡直射X射线",
        "hint": "防止强直射束损坏探测器，只记录衍射信号"
      },
      "goniometer": {
        "label_zh": "测角仪",
        "label_en": "Goniometer",
        "desc_brief": "精确旋转样品",
        "hint": "通过多角度旋转收集完整的三维衍射数据"
      },
      "cooling_system": {
        "label_zh": "冷却系统",
        "label_en": "Cooling System",
        "desc_brief": "维持样品低温",
        "hint": "常用液氮流冷却至100K左右保护晶体"
      },
      "shielding": {
        "label_zh": "屏蔽罩",
        "label_en": "Shielding",
        "desc_brief": "防护X射线泄漏",
        "hint": "铅或钢制屏蔽确保操作人员安全"
      },
      "alignment_laser": {
        "label_zh": "对准激光",
        "label_en": "Alignment Laser",
        "desc_brief": "辅助样品定位",
        "hint": "可见光激光帮助精确对准微小晶体"
      },
      "vacuum_chamber": {
