    "parts": {
      "backbone": {
        "label_zh": "主链",
        "label_en": "Backbone",
        "desc_brief": "蛋白质的主干结构",
        "hint": "由重复的N-Cα-C单元组成，决定蛋白质基本构象"
      },
      "beta_strand": {
        "label_zh": "β链",
        "label_en": "Beta Strand",
        "desc_brief": "伸展的多肽链片段",
        "hint": "β折叠由多个β链通过氢键平行或反平行排列形成"
      },
      "hydrogen_bond": {
        "label_zh": "氢键",
        "label_en": "Hydrogen Bond",
        "desc_brief": "连接β链的弱相互作用",
        "hint": "在相邻β链的羰基氧和酰胺氢之间形成，稳定β折叠结构"
      },
      "side_chain": {
        "label_zh": "侧链",
        "label_en": "Side Chain",
        "desc_brief": "氨基酸的可变基团",
        "hint": "从主链伸出，决定氨基酸类型和蛋白质功能"
      },
      "peptide_bond": {
        "label_zh": "肽键",
        "label_en": "Peptide Bond",
        "desc_brief": "连接氨基酸的共价键",
        "hint": "具有部分双键性质，呈平面刚性结构"
      },
      "solvent_molecule": {
        "label_zh": "溶剂分子",
        "label_en": "Solvent Molecule",
        "desc_brief": "周围的水或其他溶剂",
        "hint": "可能参与稳定蛋白质结构或介导分子间相互作用"
      },
      "metal_ion": {
        "label_zh": "金属离子",
        "label_en": "Metal Ion",
        "desc_brief": "结合的金属辅助因子",
        "hint": "某些蛋白质需要金属离子维持正确折叠或催化活性"
      },
      "disulfide_bridge": {
        "label_zh": "二硫键",
        "label_en": "Disulfide Bridge",
        "desc_brief": "半胱氨酸间的共价连接",
        "hint": "在胞外蛋白中常见，增强结构稳定性"
      }
    }
  },
