{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": { "noNonNullAssertion": "off" },
      "suspicious": { "noAssignInExpressions": "off" }
    }
  },
  "overrides": [
    {
      "include": ["**/tests/**", "**/*.test.ts", "**/*.test.tsx"],
      "linter": {
        "rules": {
          "performance": { "noDelete": "off" },
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignore": [
      "dist/**",
      "node_modules/**",
      "coverage/**",
      "**/*.generated.*",
      "packages/server/vendor/**"
    ]
  }
}
