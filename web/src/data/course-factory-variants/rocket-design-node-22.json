      "html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<style>\n:root{--bg:#07111f;--panel:#0d1b2e;--ink:#eef4ff;--muted:#9eb3d1;--accent:#63e6be;--accent2:#ffd166;--danger:#ff7b72;--line:#21405f}\n*{box-sizing:border-box}html,body{margin:0;height:100%;overflow:hidden;font-family:\"Avenir Next\",\"PingFang SC\",\"Noto Sans SC\",sans-serif;background:radial-gradient(circle at top,#123456 0%,#07111f 60%,#05101c 100%);color:var(--ink)}\nbody{display:flex;min-height:100vh}.wrap{display:flex;width:100%;height:100vh}.sidebar{width:230px;flex:0 0 230px;background:rgba(7,17,31,.82);border-right:1px solid rgba(255,255,255,.08);padding:18px 16px;display:flex;flex-direction:column;gap:14px}.tag{display:inline-flex;align-items:center;gap:8px;padding:6px 10px;border-radius:999px;background:rgba(99,230,190,.12);color:var(--accent);font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;width:max-content}.title{font-size:20px;font-weight:800;line-height:1.25}.desc{font-size:13px;line-height:1.65;color:var(--muted)}.scene-list{display:flex;flex-direction:column;gap:8px}.scene-btn{border:1px solid rgba(255,255,255,.1);background:#10233a;color:var(--ink);padding:10px 12px;border-radius:14px;text-align:left;cursor:pointer;transition:.18s}.scene-btn.active{background:linear-gradient(135deg,rgba(99,230,190,.22),rgba(255,209,102,.18));border-color:rgba(99,230,190,.45);transform:translateX(2px)}.hint{margin-top:auto;padding:12px;border-radius:14px;background:rgba(255,255,255,.04);font-size:12px;line-height:1.6;color:var(--muted)}.main{flex:1;display:flex;flex-direction:column;min-width:0}.top{display:flex;justify-content:space-between;align-items:center;padding:18px 22px 12px}.headline{font-size:26px;font-weight:800;letter-spacing:-.03em}.sub{font-size:13px;color:var(--muted);margin-top:4px}.metrics{display:flex;gap:12px;flex-wrap:wrap}.metric{padding:10px 14px;border-radius:14px;background:rgba(255,255,255,.05);min-width:120px}.metric .k{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}.metric .v{margin-top:4px;font-size:15px;font-weight:700}.stage{flex:1;display:grid;grid-template-columns:1fr 300px;gap:20px;padding:0 22px 20px;min-height:0}.arena{position:relative;border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.02));border:1px solid rgba(255,255,255,.08);overflow:hidden;min-height:0}.sky{position:absolute;inset:0;background:linear-gradient(180deg,rgba(125,211,252,.12),rgba(7,17,31,0) 45%)}.ground{position:absolute;left:0;right:0;bottom:0;height:82px;background:linear-gradient(180deg,#204b41,#17362e);border-top:2px dashed rgba(255,255,255,.18)}.lane{position:absolute;top:90px;bottom:82px;width:42%;border:1px dashed rgba(255,255,255,.14);border-bottom:none;border-radius:22px 22px 0 0}.lane.left{left:5%}.lane.right{right:5%}.lane-title{position:absolute;top:14px;left:50%;transform:translateX(-50%);font-size:13px;font-weight:700;color:#b7cee8}.drop-zone{position:absolute;left:0;right:0;top:56px;bottom:0}.obj{position:absolute;left:50%;transform:translate(-50%,0);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#05223a;box-shadow:0 10px 24px rgba(0,0,0,.22)}.obj.ball{width:62px;height:62px;border-radius:50%}.obj.paper{width:84px;height:22px;border-radius:10px}.obj.book{width:110px;height:30px;border-radius:10px}.obj.small{width:58px;height:58px;border-radius:50%}.obj.wood{background:#f2c078}.obj.metal{background:#8ed1fc}.obj.paperFlat{background:#f7f3df}.obj.bookObj{background:#ef6f6c;color:#fff}.shadow{position:absolute;left:50%;bottom:22px;transform:translateX(-50%);width:92px;height:16px;border-radius:50%;background:rgba(0,0,0,.2);filter:blur(2px)}.callout{padding:18px;border-radius:24px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);display:flex;flex-direction:column;gap:14px}.callout h3{margin:0;font-size:18px}.callout p{margin:0;font-size:13px;line-height:1.7;color:var(--muted)}.fact{padding:12px 14px;border-radius:16px;background:#10233a}.fact strong{display:block;font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);margin-bottom:6px}.fact span{font-size:13px;line-height:1.6;color:#d8e5f8}.controls{display:flex;gap:10px}.btn{border:none;border-radius:14px;padding:11px 16px;font-size:13px;font-weight:700;cursor:pointer}.btn.primary{background:linear-gradient(135deg,var(--accent),#8ce99a);color:#042032}.btn.secondary{background:#16314f;color:#d9e6f8;border:1px solid rgba(255,255,255,.1)}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <aside class=\"sidebar\">\n    <div class=\"tag\">Gravity Lab</div>\n    <div class=\"title\">自由落体的秘密</div>\n    <div class=\"desc\">看三组场景，专门分清“重力让它变快”和“空气把它拖慢”这两件事。</div>\n    <div class=\"scene-list\" id=\"sceneList\"></div>\n    <div class=\"hint\" id=\"hintBox\"></div>\n  </aside>\n  <main class=\"main\">\n    <div class=\"top\">\n      <div>\n        <div class=\"headline\" id=\"headline\"></div>\n        <div class=\"sub\" id=\"subline\"></div>\n      </div>\n      <div class=\"metrics\">\n        <div class=\"metric\"><div class=\"k\">核心判断</div><div class=\"v\" id=\"metricJudge\"></div></div>\n        <div class=\"metric\"><div class=\"k\">空气影响</div><div class=\"v\" id=\"metricAir\"></div></div>\n        <div class=\"metric\"><div class=\"k\">重力节奏</div><div class=\"v\">每秒约 +9.8 m/s</div></div>\n      </div>\n    </div>\n    <section class=\"stage\">\n      <div class=\"arena\">\n        <div class=\"sky\"></div>\n        <div class=\"lane left\"><div class=\"lane-title\" id=\"laneLeft\"></div><div class=\"drop-zone\" id=\"leftZone\"></div></div>\n        <div class=\"lane right\"><div class=\"lane-title\" id=\"laneRight\"></div><div class=\"drop-zone\" id=\"rightZone\"></div></div>\n        <div class=\"ground\"></div>\n      </div>\n      <div class=\"callout\">\n        <h3 id=\"takeawayTitle\"></h3>\n        <p id=\"takeawayBody\"></p>\n        <div class=\"fact\"><strong>你应该看到</strong><span id=\"observation\"></span></div>\n        <div class=\"fact\"><strong>和火箭有什么关系</strong><span id=\"rocketLink\"></span></div>\n        <div class=\"controls\">\n          <button class=\"btn primary\" id=\"replayBtn\">重播场景</button>\n          <button class=\"btn secondary\" id=\"nextBtn\">下一个场景</button>\n        </div>\n      </div>\n    </section>\n  </main>\n</div>\n<script>\nconst scenes = [\n  {name:'空气中的硬币和纸',sub:'同样高度，同时放手，但空气会偏爱面积大的轻物体。',leftLabel:'硬币',rightLabel:'平展开的纸',metricJudge:'硬币先到',metricAir:'很明显',hint:'先观察最日常的一幕：不是重力偏心，而是纸受到的空气阻力更大。',takeawayTitle:'场景 1：空气会把纸拖住',takeawayBody:'硬币和纸都受重力向下拉，但平展开的纸迎风面积更大，更容易被空气“托住”，所以看起来掉得慢。',observation:'左侧硬币更快贴近地面，右侧的纸下落时像被空气轻轻托着。',rocketLink:'火箭回收时如果打开降落伞，本质上也是故意把“迎风面积”做大，让空气来帮忙减速。',left:{cls:'ball metal',label:'硬币',color:'#8ed1fc',duration:1400},right:{cls:'paper paperFlat',label:'纸',color:'#f7f3df',duration:2400}},\n  {name:'书盖纸实验',sub:'纸贴在书上一起落，书先替纸挡住了前方空气。',leftLabel:'书 + 纸',rightLabel:'单独一本书',metricJudge:'几乎同时',metricAir:'被书削弱',hint:'这一幕最容易打破“重的一定先到”的直觉。关键是：纸前面的空气被书先处理掉了。',takeawayTitle:'场景 2：纸并没有被“特殊照顾”',takeawayBody:'当纸贴在书上，纸前方不再直接迎风，空气阻力一下子小了很多，于是它跟着书一起掉。',observation:'左右两边都快速接近地面，左边的纸没有再明显落后。',rocketLink:'工程上我们经常通过整流罩、箭体外形和贴合布局来减少迎风阻力，这和“书盖纸”的思路是一样的。',left:{cls:'book bookObj',label:'书+纸',color:'#ef6f6c',duration:1500},right:{cls:'book bookObj',label:'书',color:'#ef6f6c',duration:1500}},\n  {name:'忽略空气时的自由落体',sub:'两个外形接近、重量不同的球，在近似无空气干扰时会按同样节奏加速。',leftLabel:'钢球',rightLabel:'木球',metricJudge:'同时到达',metricAir:'接近没有',hint:'现在把空气的干扰尽量拿掉，重力留下的“共同节奏”就更清楚了。',takeawayTitle:'场景 3：g 描述的是共同的加速节奏',takeawayBody:'忽略空气时，重的和轻的都会按照同样的重力加速度变快。区别在重量，不在“每秒变快多少”这件事上。',observation:'两个球几乎同时到地。你会发现“谁更重”不再决定“谁更快到”。',rocketLink:'发动机熄火后，火箭头部、尾部和回收舱都会一起进入受重力主导的下落阶段，我们必须用这条共同节奏估算飞行曲线。',left:{cls:'small metal',label:'钢球',color:'#8ed1fc',duration:1650},right:{cls:'small wood',label:'木球',color:'#f2c078',duration:1650}},\n];\nlet index = 0;\nconst sceneList = document.getElementById('sceneList');\nfunction renderButtons(){sceneList.innerHTML=''; scenes.forEach((s,i)=>{const b=document.createElement('button'); b.className='scene-btn'+(i===index?' active':''); b.textContent=(i+1)+'. '+s.name; b.onclick=()=>{index=i; renderScene()}; sceneList.appendChild(b);});}\nfunction makeObj(zone, cfg){zone.innerHTML=''; const obj=document.createElement('div'); obj.className='obj '+cfg.cls; obj.textContent=cfg.label; obj.style.background=cfg.color; const shadow=document.createElement('div'); shadow.className='shadow'; zone.appendChild(obj); zone.appendChild(shadow); return obj;}\nfunction animate(obj,duration){obj.style.transition='none'; obj.style.top='10px'; obj.offsetHeight; obj.style.transition='top '+duration+'ms cubic-bezier(.2,.75,.25,1)'; obj.style.top='calc(100% - 94px)';}\nfunction renderScene(){ const s=scenes[index]; renderButtons(); document.getElementById('headline').textContent=s.name; document.getElementById('subline').textContent=s.sub; document.getElementById('metricJudge').textContent=s.metricJudge; document.getElementById('metricAir').textContent=s.metricAir; document.getElementById('hintBox').textContent=s.hint; document.getElementById('takeawayTitle').textContent=s.takeawayTitle; document.getElementById('takeawayBody').textContent=s.takeawayBody; document.getElementById('observation').textContent=s.observation; document.getElementById('rocketLink').textContent=s.rocketLink; document.getElementById('laneLeft').textContent=s.leftLabel; document.getElementById('laneRight').textContent=s.rightLabel; const left=makeObj(document.getElementById('leftZone'), s.left); const right=makeObj(document.getElementById('rightZone'), s.right); setTimeout(()=>{animate(left,s.left.duration); animate(right,s.right.duration);}, 80); }\ndocument.getElementById('replayBtn').onclick=()=>renderScene();\ndocument.getElementById('nextBtn').onclick=()=>{index=(index+1)%scenes.length; renderScene();};\nrenderScene();\n</script>\n</body>\n</html>",
