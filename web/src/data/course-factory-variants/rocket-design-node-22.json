      "html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<style>\n:root{--bg:#fbf7ef;--panel:#fffdf8;--ink:#202939;--muted:#66758a;--line:#e3d8c2;--accent:#f59f00;--accent2:#0ca678;--danger:#e03131}\n*{box-sizing:border-box}html,body{margin:0;height:100%;overflow:hidden;font-family:\"Avenir Next\",\"PingFang SC\",\"Noto Sans SC\",sans-serif;background:linear-gradient(180deg,#fdf8ef,#f7efe1);color:var(--ink)}body{display:flex;min-height:100vh}.wrap{display:grid;grid-template-columns:240px 1fr;height:100vh;width:100%}.side{background:rgba(255,255,255,.75);border-right:1px solid var(--line);padding:18px 16px;display:flex;flex-direction:column;gap:14px}.badge{width:max-content;padding:6px 10px;border-radius:999px;background:#fff3cd;color:#9c640c;font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.title{font-size:20px;font-weight:800;line-height:1.25}.desc{font-size:13px;line-height:1.65;color:var(--muted)}.score{display:grid;grid-template-columns:1fr 1fr;gap:10px}.card{padding:12px;border-radius:16px;background:white;border:1px solid var(--line)}.card .k{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}.card .v{margin-top:6px;font-size:18px;font-weight:800}.guide{padding:12px;border-radius:16px;background:#fff;line-height:1.65;font-size:12px;color:var(--muted);border:1px solid var(--line)}.main{padding:18px 20px 20px;display:flex;flex-direction:column;gap:16px;min-width:0}.top{display:flex;justify-content:space-between;align-items:flex-start;gap:16px}.headline{font-size:28px;font-weight:900;letter-spacing:-.03em}.sub{margin-top:6px;font-size:13px;color:var(--muted);max-width:720px}.state{padding:12px 14px;border-radius:16px;background:#fff;border:1px solid var(--line);font-size:13px;line-height:1.6;min-width:240px}.arena{position:relative;flex:1;min-height:320px;border-radius:28px;background:linear-gradient(180deg,#e3f2fd 0%,#fef6e4 68%,#d8f3dc 68%,#c7e9c0 100%);border:1px solid #d8d2c5;overflow:hidden}.lane{position:absolute;top:34px;bottom:76px;width:36%;border:2px dashed rgba(32,41,57,.16);border-bottom:none;border-radius:26px 26px 0 0}.lane.left{left:8%}.lane.right{right:8%}.lane h3{margin:12px 0 0;text-align:center;font-size:16px}.cond{margin-top:4px;text-align:center;font-size:12px;color:var(--muted)}.drop-area{position:absolute;left:0;right:0;top:90px;bottom:0}.obj{position:absolute;left:50%;transform:translateX(-50%);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;color:#203040;box-shadow:0 12px 24px rgba(32,41,57,.16)}.obj.ball{width:72px;height:72px;border-radius:50%}.obj.paper{width:102px;height:26px;border-radius:12px}.obj.book{width:118px;height:34px;border-radius:12px;color:#fff}.obj.paperBall{width:62px;height:62px;border-radius:50%}.groundLine{position:absolute;left:0;right:0;bottom:74px;border-top:2px dashed rgba(32,41,57,.26)}.controls{display:flex;flex-wrap:wrap;gap:10px;align-items:center}.pick{border:none;border-radius:14px;padding:11px 16px;font-size:13px;font-weight:800;cursor:pointer;background:#fff;border:1px solid var(--line);transition:.15s}.pick.active{transform:translateY(-1px);box-shadow:0 8px 20px rgba(32,41,57,.08);border-color:#9ec5fe;background:#eef6ff}.pick.left.active{color:#0b7285}.pick.tie.active{color:#9c640c}.pick.right.active{color:#2b8a3e}.btn{border:none;border-radius:14px;padding:11px 18px;font-size:13px;font-weight:800;cursor:pointer}.btn.primary{background:linear-gradient(135deg,#ffd166,#f59f00);color:#3d2b00}.btn.secondary{background:white;border:1px solid var(--line);color:var(--ink)}.msg{padding:14px 16px;border-radius:18px;background:#fff;border:1px solid var(--line);font-size:14px;line-height:1.7}.ok{color:#0ca678}.bad{color:#e03131}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <aside class=\"side\">\n    <div class=\"badge\">Prediction Game</div>\n    <div class=\"title\">谁先落地？</div>\n    <div class=\"desc\">先做预测，再按“释放物体”，亲眼看到结果。重点不是猜对，而是分清楚空气阻力什么时候在捣乱。</div>\n    <div class=\"score\">\n      <div class=\"card\"><div class=\"k\">回合</div><div class=\"v\" id=\"roundNum\">1 / 4</div></div>\n      <div class=\"card\"><div class=\"k\">得分</div><div class=\"v\" id=\"scoreNum\">0</div></div>\n    </div>\n    <div class=\"guide\">玩法：先选“左边先到 / 同时落地 / 右边先到”，再按“释放物体”。每一关都会给出解释，帮助你把“重力”与“空气阻力”分开。</div>\n  </aside>\n  <main class=\"main\">\n    <div class=\"top\">\n      <div>\n        <div class=\"headline\" id=\"headline\"></div>\n        <div class=\"sub\" id=\"subline\"></div>\n      </div>\n      <div class=\"state\" id=\"stateBox\">先观察条件，再做预测。</div>\n    </div>\n    <section class=\"arena\">\n      <div class=\"lane left\">\n        <h3 id=\"leftTitle\"></h3>\n        <div class=\"cond\" id=\"leftCond\"></div>\n        <div class=\"drop-area\" id=\"leftArea\"></div>\n      </div>\n      <div class=\"lane right\">\n        <h3 id=\"rightTitle\"></h3>\n        <div class=\"cond\" id=\"rightCond\"></div>\n        <div class=\"drop-area\" id=\"rightArea\"></div>\n      </div>\n      <div class=\"groundLine\"></div>\n    </section>\n    <div class=\"controls\">\n      <button class=\"pick left\" data-pick=\"left\">左边先到</button>\n      <button class=\"pick tie\" data-pick=\"tie\">同时落地</button>\n      <button class=\"pick right\" data-pick=\"right\">右边先到</button>\n      <button class=\"btn primary\" id=\"dropBtn\">释放物体</button>\n      <button class=\"btn secondary\" id=\"nextBtn\">下一关</button>\n      <button class=\"btn secondary\" id=\"resetBtn\">重新开始</button>\n    </div>\n    <div class=\"msg\" id=\"messageBox\">本游戏一共 4 关，其中有些场景看重量，有些场景看空气阻力，还有些场景要认出“书盖纸”这种特殊条件。</div>\n  </main>\n</div>\n<script>\nconst rounds = [\n  {title:'硬币 vs 平展开纸',sub:'条件：普通空气，同样高度，同时放手。',state:'空气对纸的影响很大，所以这不是单纯的“谁更重”。',left:{title:'硬币',cond:'空气中',cls:'ball',color:'#8ed1fc',duration:1400},right:{title:'平展开纸',cond:'空气中',cls:'paper',color:'#f7f3df',duration:2400},answer:'left',explain:'正确答案是左边先到。不是因为“金属被重力特别偏爱”，而是平展开的纸迎风面积更大，空气更容易把它拖慢。'},\n  {title:'书盖纸实验',sub:'条件：左边是“书和贴在上面的纸”，右边是单独一本书。',state:'想想书是不是先替纸挡住了前方空气。',left:{title:'书 + 纸',cond:'纸贴在书上',cls:'book',color:'#ef6f6c',duration:1500},right:{title:'单独一本书',cond:'空气中',cls:'book',color:'#ef6f6c',duration:1500},answer:'tie',explain:'正确答案是同时落地。纸这次没有明显落后，因为它前面的空气被书先“劈开”了，阻力大幅减小。'},\n  {title:'钢球 vs 木球',sub:'条件：两个球外形接近，忽略空气影响。',state:'这时要抓住“自由落体”的本质：同样的重力加速度。',left:{title:'钢球',cond:'近似无空气',cls:'ball',color:'#8ed1fc',duration:1650},right:{title:'木球',cond:'近似无空气',cls:'ball',color:'#f2c078',duration:1650},answer:'tie',explain:'正确答案是同时落地。忽略空气后，重的和轻的都会按照同样的重力节奏变快。重量不同，不代表“每秒变快的程度”不同。'},\n  {title:'纸团 vs 平展开纸',sub:'条件：两张纸质量差不多，但形状不同。',state:'这一关专门提醒你：形状会改变空气阻力。',left:{title:'揉成纸团',cond:'空气中',cls:'paperBall',color:'#e9d8a6',duration:1550},right:{title:'平展开纸',cond:'空气中',cls:'paper',color:'#f7f3df',duration:2400},answer:'left',explain:'正确答案是左边先到。质量接近时，形状差异会非常明显地改变空气阻力；纸团更紧凑，所以更快到地。'}\n];\nlet idx=0, score=0, picked=null, locked=false;\nconst messageBox=document.getElementById('messageBox');\nconst stateBox=document.getElementById('stateBox');\nfunction mount(area, cfg){area.innerHTML=''; const obj=document.createElement('div'); obj.className='obj '+cfg.cls; obj.textContent=cfg.title; obj.style.background=cfg.color; obj.style.top='10px'; area.appendChild(obj); return obj;}\nfunction applyRound(){const r=rounds[idx]; document.getElementById('headline').textContent=r.title; document.getElementById('subline').textContent=r.sub; document.getElementById('stateBox').textContent=r.state; document.getElementById('roundNum').textContent=(idx+1)+' / '+rounds.length; document.getElementById('scoreNum').textContent=String(score); document.getElementById('leftTitle').textContent=r.left.title; document.getElementById('leftCond').textContent=r.left.cond; document.getElementById('rightTitle').textContent=r.right.title; document.getElementById('rightCond').textContent=r.right.cond; mount(document.getElementById('leftArea'), r.left); mount(document.getElementById('rightArea'), r.right); picked=null; locked=false; document.querySelectorAll('.pick').forEach(b=>b.classList.remove('active')); messageBox.textContent='先做预测，再按“释放物体”。'; messageBox.className='msg';}\nfunction animate(el,duration){el.style.transition='none'; el.style.top='10px'; el.offsetHeight; el.style.transition='top '+duration+'ms cubic-bezier(.2,.75,.25,1)'; el.style.top='calc(100% - 92px)';}\ndocument.querySelectorAll('.pick').forEach(btn=>{btn.onclick=()=>{if(locked)return; picked=btn.dataset.pick; document.querySelectorAll('.pick').forEach(b=>b.classList.remove('active')); btn.classList.add('active');}});\ndocument.getElementById('dropBtn').onclick=()=>{if(locked)return; if(!picked){messageBox.textContent='还没选择预测。先判断“左边先到 / 同时落地 / 右边先到”。'; messageBox.className='msg bad'; return;} locked=true; const r=rounds[idx]; const left=document.querySelector('#leftArea .obj'); const right=document.querySelector('#rightArea .obj'); animate(left,r.left.duration); animate(right,r.right.duration); stateBox.textContent='正在下落……注意谁先碰到地线。'; setTimeout(()=>{const ok=picked===r.answer; if(ok) score+=1; document.getElementById('scoreNum').textContent=String(score); messageBox.innerHTML=(ok?'<span class=\"ok\">回答正确。</span> ':'<span class=\"bad\">这次猜错了。</span> ')+r.explain; messageBox.className='msg'; stateBox.textContent='结果已揭晓。看懂原因，比答对更重要。';}, Math.max(r.left.duration,r.right.duration)+120);};\ndocument.getElementById('nextBtn').onclick=()=>{idx=(idx+1)%rounds.length; applyRound();};\ndocument.getElementById('resetBtn').onclick=()=>{idx=0; score=0; applyRound();};\napplyRound();\n</script>\n</body>\n</html>",
