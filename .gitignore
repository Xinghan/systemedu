# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.coverage
.coverage.*
tests/student/_artifacts/

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
!.env.example

# 本地部署密码 (绝不 commit; deploy-student.sh 启动时自动 source 它设 SSHPASS)
scripts/deploy-secret.local
deploy-secret.local
*.secret.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python / Django
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
venv/
.venv/
env/
db.sqlite3
db.sqlite3-journal
.qdrant_data/
*.log
staticfiles/
media/

# Caches / local tooling state
.cache/
# .claude/ contains per-project Claude Code state (commands, settings,
# sessions). Ignore by default but allow .claude/skills/ to be tracked so
# project-scoped skills (like course_factory) live in version control.
.claude/*
!.claude/skills/
.pytest_cache/
.ruff_cache/

# Playwright test run artifacts
test-results/
playwright-report/

# spec 019+: 项目内容数据从此移到独立仓库 systemeducontent (~/Dev/systemeducontent)。
# systemedu repo 不再 track projects/ 内容。本地 projects/ 目录运行时由
# gateway 创建/扫描，但内容由用户从内容服务下载或本地 link 进来。
# 必须用 /projects/ 锚定根目录, 否则会误伤 web/src/app/(dashboard)/projects/
/projects/

# spec 022+: 内容创作工作区, 不进 git
# blueprints (从 systemeduidea sync), generated (Claude Code 生成产物),
# dist (导出 tarball)
/content-workspace/

# spec 023+: library service 运行时数据 (DB + 媒体文件)
# 锚定根目录, 避免误伤 packages/library-app/library_data/ 同名目录
/library_data/
packages/library-app/library_data/

# Ad-hoc / throwaway scripts at repo root (underscore prefix convention):
#   _debug_*, _regen_*, _fix_*, _gen_*, _verify_*, _capture_*, _smoke*, _check_*
# These are one-shot utilities kept locally; rename without the underscore
# (e.g. fix_mars_games.py) to commit them as real project scripts.
/_*.mjs
/_*.py
/_*.html
# scripts/ — course factory 一次性 debug/regen 产物不进仓库；但 test_anim_* /
# _fix_*.py / _gen_*.py 是长期测试/数据脚本，故意不 ignore。
scripts/_debug_*
scripts/_regen_*
.data/
