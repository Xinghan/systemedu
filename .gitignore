# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python / Django
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
venv/
.venv/
env/
db.sqlite3
db.sqlite3-journal
.qdrant_data/
*.log
staticfiles/
media/

# Caches / local tooling state
.cache/
# .claude/ contains per-project Claude Code state (commands, settings,
# sessions). Ignore by default but allow .claude/skills/ to be tracked so
# project-scoped skills (like course_factory) live in version control.
.claude/*
!.claude/skills/
.pytest_cache/
.ruff_cache/

# Playwright test run artifacts
test-results/
playwright-report/

# Ad-hoc / throwaway scripts at repo root (underscore prefix convention):
#   _debug_*, _regen_*, _fix_*, _gen_*, _verify_*, _capture_*, _smoke*, _check_*
# These are one-shot utilities kept locally; rename without the underscore
# (e.g. fix_mars_games.py) to commit them as real project scripts.
/_*.mjs
/_*.py
/_*.html
# scripts/ — course factory 一次性 debug/regen 产物不进仓库；但 test_anim_* /
# _fix_*.py / _gen_*.py 是长期测试/数据脚本，故意不 ignore。
scripts/_debug_*
scripts/_regen_*
