{
  "id": "phys",
  "name_zh": "物理",
  "name_en": "Physics",
  "color": "#78C8FF",
  "nodes": [
    {
      "id": "phys.kine.position_time",
      "name_zh": "位置-时间图",
      "name_en": "Position-Time Graph",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "用坐标图描述物体随时间的位置变化，理解直线斜率代表运动快慢，初步建立运动可视化语言。"
    },
    {
      "id": "phys.kine.velocity",
      "name_zh": "速度",
      "name_en": "Velocity",
      "depth_level": "K7",
      "prerequisites": ["phys.kine.position_time"],
      "description": "速度是单位时间内位移的变化，区分平均速度与瞬时速度，理解方向性使速度成为矢量。"
    },
    {
      "id": "phys.kine.acceleration",
      "name_zh": "加速度",
      "name_en": "Acceleration",
      "depth_level": "K7",
      "prerequisites": ["phys.kine.velocity"],
      "description": "加速度描述速度随时间的变化率，理解匀加速运动的 v-t 图与位移公式 s = v0·t + 1/2·a·t²。"
    },
    {
      "id": "phys.kine.projectile",
      "name_zh": "抛体运动",
      "name_en": "Projectile Motion",
      "depth_level": "K9",
      "prerequisites": ["phys.kine.acceleration"],
      "description": "把运动分解为水平匀速 + 竖直自由落体，分析射程、最大高度与轨迹抛物线。"
    },
    {
      "id": "phys.kine.circular_motion",
      "name_zh": "圆周运动",
      "name_en": "Circular Motion",
      "depth_level": "K9",
      "prerequisites": ["phys.kine.acceleration"],
      "description": "匀速圆周运动的向心加速度 v²/r 始终指向圆心，速度方向不断改变但大小不变。"
    },
    {
      "id": "phys.kine.relative_motion",
      "name_zh": "相对运动",
      "name_en": "Relative Motion",
      "depth_level": "K9",
      "prerequisites": ["phys.kine.velocity"],
      "description": "运动是相对参考系的，矢量加减得出相对速度，例如船在河中的合速度。"
    },
    {
      "id": "phys.kine.angular_velocity",
      "name_zh": "角速度",
      "name_en": "Angular Velocity",
      "depth_level": "K11",
      "prerequisites": ["phys.kine.circular_motion"],
      "description": "角速度 ω = Δθ/Δt 描述转动快慢，与线速度满足 v = ω·r，为转动学奠基。"
    },
    {
      "id": "phys.kine.rotation",
      "name_zh": "转动",
      "name_en": "Rotational Motion",
      "depth_level": "K11",
      "prerequisites": ["phys.kine.angular_velocity"],
      "description": "刚体绕轴转动的角位移、角速度、角加速度类比平动，转动惯量 I 取代质量。"
    },

    {
      "id": "phys.force.newton_1",
      "name_zh": "牛顿第一定律 惯性",
      "name_en": "Newton's First Law (Inertia)",
      "depth_level": "K7",
      "prerequisites": ["phys.kine.velocity"],
      "description": "物体保持静止或匀速直线运动，除非受外力作用；惯性是物体保持运动状态的性质。"
    },
    {
      "id": "phys.force.newton_2",
      "name_zh": "牛顿第二定律 F=ma",
      "name_en": "Newton's Second Law (F=ma)",
      "depth_level": "K7",
      "prerequisites": ["phys.kine.acceleration", "phys.force.newton_1"],
      "description": "合外力等于质量乘以加速度，F、m、a 三量关系是经典力学的核心方程。"
    },
    {
      "id": "phys.force.newton_3",
      "name_zh": "牛顿第三定律 作用反作用",
      "name_en": "Newton's Third Law (Action-Reaction)",
      "depth_level": "K7",
      "prerequisites": ["phys.force.newton_1"],
      "description": "两个物体之间的作用力与反作用力大小相等、方向相反、作用在不同物体上。"
    },
    {
      "id": "phys.force.friction",
      "name_zh": "摩擦力",
      "name_en": "Friction",
      "depth_level": "K7",
      "prerequisites": ["phys.force.newton_2"],
      "description": "静摩擦与动摩擦的方向阻碍相对运动趋势或运动，f = μN 与接触面性质相关。"
    },
    {
      "id": "phys.force.gravity",
      "name_zh": "重力",
      "name_en": "Gravity",
      "depth_level": "K7",
      "prerequisites": ["phys.force.newton_2"],
      "description": "地面附近重力 G = mg，g ≈ 9.8 m/s²；万有引力是更普适的形式 F = G·m1·m2/r²。"
    },
    {
      "id": "phys.force.spring",
      "name_zh": "弹簧力 胡克定律",
      "name_en": "Spring Force (Hooke's Law)",
      "depth_level": "K9",
      "prerequisites": ["phys.force.newton_2"],
      "description": "弹簧在弹性限度内 F = -kx，回复力与形变量成正比且方向相反，是简谐振动的基础。"
    },
    {
      "id": "phys.force.tension",
      "name_zh": "张力",
      "name_en": "Tension",
      "depth_level": "K9",
      "prerequisites": ["phys.force.newton_3"],
      "description": "绳/线/杆中沿轴向传递的拉力，理想轻绳张力处处相等，应用于滑轮组与吊挂系统。"
    },
    {
      "id": "phys.force.normal",
      "name_zh": "法向力",
      "name_en": "Normal Force",
      "depth_level": "K9",
      "prerequisites": ["phys.force.newton_3"],
      "description": "接触面对物体垂直于表面的支持力，由约束产生，大小由其他力的平衡决定。"
    },
    {
      "id": "phys.force.torque",
      "name_zh": "力矩",
      "name_en": "Torque",
      "depth_level": "K11",
      "prerequisites": ["phys.force.newton_2", "phys.kine.rotation"],
      "description": "力矩 τ = r × F 是使物体绕轴转动的原因，决定角加速度 τ = I·α。"
    },
    {
      "id": "phys.force.equilibrium",
      "name_zh": "力学平衡",
      "name_en": "Mechanical Equilibrium",
      "depth_level": "K9",
      "prerequisites": ["phys.force.newton_1", "phys.force.gravity"],
      "description": "合力为零且合力矩为零时物体处于平衡，包括静止与匀速；常用受力分析与正交分解求解。"
    },

    {
      "id": "phys.energy.kinetic",
      "name_zh": "动能",
      "name_en": "Kinetic Energy",
      "depth_level": "K7",
      "prerequisites": ["phys.kine.velocity"],
      "description": "运动物体具有的能量 Ek = 1/2·m·v²，与速度平方成正比，是机械能的一部分。"
    },
    {
      "id": "phys.energy.potential",
      "name_zh": "势能",
      "name_en": "Potential Energy",
      "depth_level": "K7",
      "prerequisites": ["phys.force.gravity"],
      "description": "由位置或形变储存的能量，重力势能 Ep = mgh，弹性势能 Ep = 1/2·k·x²。"
    },
    {
      "id": "phys.energy.work",
      "name_zh": "功",
      "name_en": "Work",
      "depth_level": "K7",
      "prerequisites": ["phys.force.newton_2"],
      "description": "力沿位移方向做功 W = F·s·cosθ，是能量传递的量度，正功增加能量，负功减少能量。"
    },
    {
      "id": "phys.energy.conservation",
      "name_zh": "能量守恒",
      "name_en": "Conservation of Energy",
      "depth_level": "K7",
      "prerequisites": ["phys.energy.kinetic", "phys.energy.potential", "phys.energy.work"],
      "description": "能量既不会凭空产生也不会凭空消失，只在不同形式之间转化；机械能守恒是其特例。"
    },
    {
      "id": "phys.energy.power",
      "name_zh": "功率",
      "name_en": "Power",
      "depth_level": "K9",
      "prerequisites": ["phys.energy.work"],
      "description": "功率 P = W/t = F·v 描述做功快慢，单位瓦特，工程中常用千瓦与马力换算。"
    },
    {
      "id": "phys.energy.momentum",
      "name_zh": "动量",
      "name_en": "Momentum",
      "depth_level": "K9",
      "prerequisites": ["phys.kine.velocity", "phys.force.newton_2"],
      "description": "动量 p = m·v 是矢量，冲量等于动量变化 I = F·Δt = Δp，揭示力作用时间的效应。"
    },
    {
      "id": "phys.energy.momentum_conservation",
      "name_zh": "动量守恒",
      "name_en": "Conservation of Momentum",
      "depth_level": "K9",
      "prerequisites": ["phys.energy.momentum", "phys.force.newton_3"],
      "description": "系统不受外力或外力之和为零时总动量保持不变，应用于碰撞、爆炸、反冲问题。"
    },
    {
      "id": "phys.energy.elastic_collision",
      "name_zh": "弹性碰撞",
      "name_en": "Elastic Collision",
      "depth_level": "K11",
      "prerequisites": ["phys.energy.momentum_conservation", "phys.energy.conservation"],
      "description": "动量和动能同时守恒的碰撞，求解后两速度公式，是分子运动和粒子物理的理想模型。"
    },

    {
      "id": "phys.wave.basic",
      "name_zh": "波动基础",
      "name_en": "Wave Basics",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "波是扰动的传播，理解波长 λ、频率 f、振幅 A、波速 v 与关系 v = λ·f。"
    },
    {
      "id": "phys.wave.sound",
      "name_zh": "声波",
      "name_en": "Sound Waves",
      "depth_level": "K7",
      "prerequisites": ["phys.wave.basic"],
      "description": "声波是介质中的纵波，理解响度、音调、音色，常温空气中声速约 340 m/s。"
    },
    {
      "id": "phys.wave.interference",
      "name_zh": "干涉",
      "name_en": "Interference",
      "depth_level": "K11",
      "prerequisites": ["phys.wave.basic"],
      "description": "两列同频率相干波叠加产生加强或减弱条纹，杨氏双缝实验是经典验证。"
    },
    {
      "id": "phys.wave.diffraction",
      "name_zh": "衍射",
      "name_en": "Diffraction",
      "depth_level": "K11",
      "prerequisites": ["phys.wave.basic"],
      "description": "波遇障碍或孔径绕过传播的现象，孔径与波长可比时衍射明显，体现波动性。"
    },
    {
      "id": "phys.wave.doppler",
      "name_zh": "多普勒效应",
      "name_en": "Doppler Effect",
      "depth_level": "K11",
      "prerequisites": ["phys.wave.basic", "phys.kine.relative_motion"],
      "description": "波源与观察者相对运动导致观察频率改变，应用于雷达测速、医学超声、天文红移。"
    },

    {
      "id": "phys.opt.color",
      "name_zh": "颜色",
      "name_en": "Color",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "可见光由不同波长组成，物体颜色来自反射或透射的光谱，三原色合成感知所有颜色。"
    },
    {
      "id": "phys.opt.reflection_refraction",
      "name_zh": "反射 折射",
      "name_en": "Reflection and Refraction",
      "depth_level": "K7",
      "prerequisites": ["phys.opt.color"],
      "description": "光在界面遵守反射定律和斯涅尔折射定律 n1·sinθ1 = n2·sinθ2，全反射用于光纤。"
    },
    {
      "id": "phys.opt.lens",
      "name_zh": "透镜成像",
      "name_en": "Lens Imaging",
      "depth_level": "K7",
      "prerequisites": ["phys.opt.reflection_refraction"],
      "description": "凸透镜会聚、凹透镜发散，透镜方程 1/u + 1/v = 1/f 决定像距与放大率。"
    },
    {
      "id": "phys.opt.rayleigh_scatter",
      "name_zh": "瑞利散射",
      "name_en": "Rayleigh Scattering",
      "depth_level": "K11",
      "prerequisites": ["phys.opt.color", "phys.wave.basic"],
      "description": "粒子远小于波长时散射强度 ∝ 1/λ⁴，蓝光散射远强于红光，解释天空蓝与晚霞红。"
    },
    {
      "id": "phys.opt.mie_scatter",
      "name_zh": "Mie 散射",
      "name_en": "Mie Scattering",
      "depth_level": "K11",
      "prerequisites": ["phys.opt.rayleigh_scatter", "phys.wave.diffraction"],
      "description": "粒子尺寸与波长相近时的散射理论，PM2.5 与云滴几乎等强散射各色光呈白色，PMS5003 激光传感器据此测量颗粒物。"
    },
    {
      "id": "phys.opt.laser",
      "name_zh": "激光原理",
      "name_en": "Laser Principles",
      "depth_level": "K11",
      "prerequisites": ["phys.opt.reflection_refraction"],
      "description": "受激辐射放大产生单色、相干、方向性强的光束，谐振腔与粒子数反转是核心条件。"
    },

    {
      "id": "phys.thermal.temp_heat",
      "name_zh": "温度 热量",
      "name_en": "Temperature and Heat",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "温度表示分子平均动能，热量是能量传递；摄氏、华氏、开尔文三种温标的换算。"
    },
    {
      "id": "phys.thermal.thermal_eq",
      "name_zh": "热平衡",
      "name_en": "Thermal Equilibrium",
      "depth_level": "K7",
      "prerequisites": ["phys.thermal.temp_heat"],
      "description": "接触物体长时间后达到相同温度即热平衡，热力学第零定律是温度计原理的基础。"
    },
    {
      "id": "phys.thermal.specific_heat",
      "name_zh": "比热容",
      "name_en": "Specific Heat Capacity",
      "depth_level": "K9",
      "prerequisites": ["phys.thermal.thermal_eq"],
      "description": "Q = c·m·ΔT，比热容 c 反映物质升温难易，水的比热较大调节地球气候。"
    },
    {
      "id": "phys.thermal.ideal_gas",
      "name_zh": "理想气体定律",
      "name_en": "Ideal Gas Law",
      "depth_level": "K11",
      "prerequisites": ["phys.thermal.specific_heat"],
      "description": "pV = nRT 联系压强、体积、温度、物质的量，从微观分子运动模型导出。"
    },
    {
      "id": "phys.thermal.entropy",
      "name_zh": "熵 热力学第二定律",
      "name_en": "Entropy and the Second Law",
      "depth_level": "K13",
      "prerequisites": ["phys.thermal.ideal_gas", "phys.energy.conservation"],
      "description": "熵度量系统无序程度，孤立系统熵不减；热不能自发从低温流向高温，决定热机效率上限。"
    },

    {
      "id": "phys.em.charge",
      "name_zh": "电荷",
      "name_en": "Electric Charge",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "正负电荷的相互作用，库仑定律 F = k·q1·q2/r²，电荷守恒与量子化（电子电荷 e）。"
    },
    {
      "id": "phys.em.current_voltage",
      "name_zh": "电流 电压",
      "name_en": "Current and Voltage",
      "depth_level": "K7",
      "prerequisites": ["phys.em.charge"],
      "description": "电流 I = Q/t 是电荷的定向移动，电压是单位电荷的电势能差，安培与伏特单位定义。"
    },
    {
      "id": "phys.em.ohm_law",
      "name_zh": "欧姆定律",
      "name_en": "Ohm's Law",
      "depth_level": "K7",
      "prerequisites": ["phys.em.current_voltage"],
      "description": "U = I·R，导体两端电压与电流成正比，电阻 R 取决于材料、长度、截面与温度。"
    },
    {
      "id": "phys.em.field_basic",
      "name_zh": "电场磁场基础",
      "name_en": "Electric and Magnetic Fields",
      "depth_level": "K11",
      "prerequisites": ["phys.em.charge", "phys.em.current_voltage"],
      "description": "电场 E = F/q 描述空间力的分布，运动电荷产生磁场，洛伦兹力 F = qv × B 统合两者。"
    },
    {
      "id": "phys.em.electromagnetic_wave",
      "name_zh": "电磁波",
      "name_en": "Electromagnetic Waves",
      "depth_level": "K11",
      "prerequisites": ["phys.em.field_basic", "phys.wave.basic"],
      "description": "变化的电场与磁场相互激发以光速 c 传播，覆盖无线电、微波、可见光、X 射线等谱段。"
    },

    {
      "id": "phys.modern.photon_quantum",
      "name_zh": "光子 量子化",
      "name_en": "Photons and Quantization",
      "depth_level": "K13",
      "prerequisites": ["phys.em.electromagnetic_wave"],
      "description": "光以能量子 E = h·f 的形式传递，光电效应验证粒子性，开启量子力学纪元。"
    },
    {
      "id": "phys.modern.special_relativity",
      "name_zh": "狭义相对论",
      "name_en": "Special Relativity",
      "depth_level": "K13",
      "prerequisites": ["phys.kine.relative_motion", "phys.em.electromagnetic_wave"],
      "description": "光速在所有惯性系中不变，导出时间膨胀、长度收缩、质能等价 E = mc²。"
    },
    {
      "id": "phys.modern.uncertainty",
      "name_zh": "不确定性原理",
      "name_en": "Uncertainty Principle",
      "depth_level": "K13",
      "prerequisites": ["phys.modern.photon_quantum"],
      "description": "Δx·Δp ≥ ℏ/2，位置与动量不能同时精确确定，是量子世界的根本限制。"
    }
  ]
}
