{
  "id": "bio",
  "name_zh": "生物",
  "name_en": "Biology",
  "color": "#67C28C",
  "nodes": [
    {
      "id": "bio.basic.living_thing",
      "name_zh": "生物与非生物",
      "name_en": "Living vs Non-living",
      "depth_level": "K1",
      "prerequisites": [],
      "description": "区分生物与非生物：什么会动、会长大、会繁殖；石头、水与小猫的差别。"
    },
    {
      "id": "bio.basic.life_traits",
      "name_zh": "生命特征",
      "name_en": "Characteristics of Life",
      "depth_level": "K3",
      "prerequisites": ["bio.basic.living_thing"],
      "description": "生命的七大特征：营养、呼吸、排泄、运动、感应、生长、繁殖。"
    },
    {
      "id": "bio.basic.classification",
      "name_zh": "五界分类",
      "name_en": "Five Kingdoms Classification",
      "depth_level": "K5",
      "prerequisites": ["bio.basic.life_traits"],
      "description": "生物五界分类：动物、植物、真菌、原生生物、原核生物的基本区别。"
    },
    {
      "id": "bio.basic.species",
      "name_zh": "物种概念",
      "name_en": "Species Concept",
      "depth_level": "K5",
      "prerequisites": ["bio.basic.classification"],
      "description": "物种的定义：能相互交配产生可育后代的生物群；二名法命名规则。"
    },
    {
      "id": "bio.basic.ecosystem_basic",
      "name_zh": "生态系统入门",
      "name_en": "Ecosystem Basics",
      "depth_level": "K5",
      "prerequisites": ["bio.basic.classification"],
      "description": "生态系统的组成：生产者、消费者、分解者与非生物环境的相互作用。"
    },

    {
      "id": "bio.cell.basic",
      "name_zh": "细胞基础",
      "name_en": "Cell Basics",
      "depth_level": "K5",
      "prerequisites": ["bio.basic.life_traits"],
      "description": "细胞是生命的基本单位；原核细胞与真核细胞的差异，动物细胞与植物细胞对比。"
    },
    {
      "id": "bio.cell.organelle",
      "name_zh": "细胞器",
      "name_en": "Organelles",
      "depth_level": "K7",
      "prerequisites": ["bio.cell.basic"],
      "description": "主要细胞器：核、线粒体、叶绿体、内质网、高尔基体、溶酶体的功能。"
    },
    {
      "id": "bio.cell.membrane",
      "name_zh": "细胞膜",
      "name_en": "Cell Membrane",
      "depth_level": "K9",
      "prerequisites": ["bio.cell.organelle"],
      "description": "磷脂双层结构；流动镶嵌模型；被动运输、主动运输、内吞与外排。"
    },
    {
      "id": "bio.cell.mitosis",
      "name_zh": "有丝分裂",
      "name_en": "Mitosis",
      "depth_level": "K9",
      "prerequisites": ["bio.cell.basic", "bio.cell.organelle"],
      "description": "细胞周期与有丝分裂的前中后末四期；染色体复制与平均分配。"
    },
    {
      "id": "bio.cell.meiosis",
      "name_zh": "减数分裂",
      "name_en": "Meiosis",
      "depth_level": "K11",
      "prerequisites": ["bio.cell.mitosis"],
      "description": "减数分裂两次分裂产生配子；同源染色体配对、交叉互换与遗传多样性。"
    },
    {
      "id": "bio.cell.protein_synthesis",
      "name_zh": "蛋白质合成",
      "name_en": "Protein Synthesis",
      "depth_level": "K11",
      "prerequisites": ["bio.cell.organelle", "bio.cell.membrane"],
      "description": "中心法则：DNA 转录为 mRNA，核糖体翻译为蛋白质；密码子表与终止信号。"
    },
    {
      "id": "bio.cell.cell_signal",
      "name_zh": "细胞信号",
      "name_en": "Cell Signaling",
      "depth_level": "K11",
      "prerequisites": ["bio.cell.membrane"],
      "description": "受体—配体识别、第二信使、信号级联放大；自分泌、旁分泌、内分泌、突触信号。"
    },
    {
      "id": "bio.cell.cancer",
      "name_zh": "癌细胞",
      "name_en": "Cancer Cells",
      "depth_level": "K13",
      "prerequisites": ["bio.cell.mitosis", "bio.cell.cell_signal"],
      "description": "细胞周期调控失控；原癌基因、抑癌基因与凋亡逃逸；肿瘤微环境与转移。"
    },

    {
      "id": "bio.gen.mendel",
      "name_zh": "孟德尔遗传定律",
      "name_en": "Mendelian Genetics",
      "depth_level": "K9",
      "prerequisites": ["bio.cell.mitosis"],
      "description": "分离定律与自由组合定律；显性、隐性、基因型与表现型；豌豆杂交实验。"
    },
    {
      "id": "bio.gen.dna_basic",
      "name_zh": "DNA 基础",
      "name_en": "DNA Basics",
      "depth_level": "K9",
      "prerequisites": ["bio.cell.basic"],
      "description": "DNA 双螺旋结构、四种碱基 ATCG、互补配对；Watson-Crick 模型简介。"
    },
    {
      "id": "bio.gen.gene_chromosome",
      "name_zh": "基因与染色体",
      "name_en": "Genes and Chromosomes",
      "depth_level": "K9",
      "prerequisites": ["bio.gen.dna_basic", "bio.gen.mendel"],
      "description": "基因是 DNA 上一段编码序列；染色体是基因的载体；人类 23 对染色体。"
    },
    {
      "id": "bio.gen.replication",
      "name_zh": "DNA 复制",
      "name_en": "DNA Replication",
      "depth_level": "K11",
      "prerequisites": ["bio.gen.dna_basic"],
      "description": "半保留复制；DNA 聚合酶、解旋酶、引物酶；前导链与后随链；冈崎片段。"
    },
    {
      "id": "bio.gen.mutation",
      "name_zh": "突变",
      "name_en": "Mutation",
      "depth_level": "K11",
      "prerequisites": ["bio.gen.replication"],
      "description": "点突变、移码突变、染色体畸变；自发突变与诱变；进化与疾病的源泉。"
    },
    {
      "id": "bio.gen.gene_expression",
      "name_zh": "基因表达",
      "name_en": "Gene Expression",
      "depth_level": "K11",
      "prerequisites": ["bio.gen.gene_chromosome", "bio.cell.protein_synthesis"],
      "description": "转录调控、启动子、增强子、转录因子；表观遗传修饰与组织特异性表达。"
    },
    {
      "id": "bio.gen.crispr",
      "name_zh": "CRISPR 基因编辑",
      "name_en": "CRISPR Gene Editing",
      "depth_level": "K13",
      "prerequisites": ["bio.gen.gene_expression", "bio.gen.replication"],
      "description": "CRISPR-Cas9 系统起源于细菌免疫；sgRNA 引导切割、HDR/NHEJ 修复；应用与伦理。"
    },
    {
      "id": "bio.gen.genome",
      "name_zh": "基因组学",
      "name_en": "Genomics",
      "depth_level": "K13",
      "prerequisites": ["bio.gen.gene_expression"],
      "description": "全基因组测序、人类基因组计划、比较基因组学；GWAS 与个体化医疗。"
    },

    {
      "id": "bio.evo.darwin",
      "name_zh": "达尔文进化论",
      "name_en": "Darwinian Evolution",
      "depth_level": "K9",
      "prerequisites": ["bio.basic.species"],
      "description": "达尔文与《物种起源》；变异、遗传、过度繁殖、生存斗争与适者生存。"
    },
    {
      "id": "bio.evo.natural_selection",
      "name_zh": "自然选择",
      "name_en": "Natural Selection",
      "depth_level": "K9",
      "prerequisites": ["bio.evo.darwin"],
      "description": "自然选择四要素：变异、遗传、选择压、差别繁殖；定向、稳定、分歧选择。"
    },
    {
      "id": "bio.evo.speciation",
      "name_zh": "物种形成",
      "name_en": "Speciation",
      "depth_level": "K11",
      "prerequisites": ["bio.evo.natural_selection", "bio.gen.mutation"],
      "description": "异域物种形成与同域物种形成；地理隔离、生殖隔离与适应辐射。"
    },
    {
      "id": "bio.evo.phylogeny",
      "name_zh": "系统发生树",
      "name_en": "Phylogenetic Tree",
      "depth_level": "K11",
      "prerequisites": ["bio.evo.speciation"],
      "description": "通过形态、分子证据构建生物谱系树；分子钟与共同祖先推断。"
    },
    {
      "id": "bio.evo.fossil_record",
      "name_zh": "化石记录",
      "name_en": "Fossil Record",
      "depth_level": "K9",
      "prerequisites": ["bio.evo.darwin"],
      "description": "化石形成条件、相对/绝对年代测定、过渡型化石与生命大爆发证据。"
    },

    {
      "id": "bio.eco.food_chain",
      "name_zh": "食物链",
      "name_en": "Food Chain",
      "depth_level": "K5",
      "prerequisites": ["bio.basic.ecosystem_basic"],
      "description": "生产者—初级消费者—次级消费者—顶级消费者；能量沿营养级单向流动。"
    },
    {
      "id": "bio.eco.food_web",
      "name_zh": "食物网",
      "name_en": "Food Web",
      "depth_level": "K7",
      "prerequisites": ["bio.eco.food_chain"],
      "description": "多条食物链相互交织形成食物网；关键物种与生态系统稳定性。"
    },
    {
      "id": "bio.eco.population",
      "name_zh": "种群动力学",
      "name_en": "Population Dynamics",
      "depth_level": "K9",
      "prerequisites": ["bio.eco.food_web"],
      "description": "种群密度、出生率、死亡率；指数增长与逻辑斯蒂增长；环境容纳量 K。"
    },
    {
      "id": "bio.eco.biodiversity",
      "name_zh": "生物多样性",
      "name_en": "Biodiversity",
      "depth_level": "K9",
      "prerequisites": ["bio.eco.food_web", "bio.basic.species"],
      "description": "基因、物种、生态系统三层多样性；多样性热点与保护生物学策略。"
    },
    {
      "id": "bio.eco.symbiosis",
      "name_zh": "共生关系",
      "name_en": "Symbiosis",
      "depth_level": "K9",
      "prerequisites": ["bio.eco.food_web"],
      "description": "互利共生、偏利共生、寄生与竞争；典型案例（豆科—根瘤菌、珊瑚—虫黄藻）。"
    },
    {
      "id": "bio.eco.succession",
      "name_zh": "生态演替",
      "name_en": "Ecological Succession",
      "depth_level": "K11",
      "prerequisites": ["bio.eco.population", "bio.eco.biodiversity"],
      "description": "初生演替与次生演替；先锋种、顶极群落与人类干扰对演替轨迹的影响。"
    },

    {
      "id": "bio.phys.respiration",
      "name_zh": "呼吸系统",
      "name_en": "Respiratory System",
      "depth_level": "K7",
      "prerequisites": ["bio.cell.organelle"],
      "description": "鼻—气管—支气管—肺泡；气体交换原理、呼吸肌与呼吸频率调节。"
    },
    {
      "id": "bio.phys.circulation",
      "name_zh": "循环系统",
      "name_en": "Circulatory System",
      "depth_level": "K7",
      "prerequisites": ["bio.cell.organelle"],
      "description": "心脏四腔结构、动脉静脉毛细血管、体循环与肺循环；血液成分与运输功能。"
    },
    {
      "id": "bio.phys.digestion",
      "name_zh": "消化系统",
      "name_en": "Digestive System",
      "depth_level": "K7",
      "prerequisites": ["bio.cell.organelle"],
      "description": "口腔—食道—胃—小肠—大肠；机械消化与化学消化；肝、胰、胆的辅助作用。"
    },
    {
      "id": "bio.phys.nervous",
      "name_zh": "神经系统",
      "name_en": "Nervous System",
      "depth_level": "K9",
      "prerequisites": ["bio.phys.circulation"],
      "description": "中枢神经与周围神经；反射弧；交感与副交感神经的拮抗调节。"
    },
    {
      "id": "bio.phys.endocrine",
      "name_zh": "内分泌系统",
      "name_en": "Endocrine System",
      "depth_level": "K11",
      "prerequisites": ["bio.phys.nervous", "bio.cell.cell_signal"],
      "description": "下丘脑—垂体—靶腺轴；胰岛素、甲状腺素、肾上腺素等激素与负反馈调节。"
    },
    {
      "id": "bio.phys.immune",
      "name_zh": "免疫系统",
      "name_en": "Immune System",
      "depth_level": "K11",
      "prerequisites": ["bio.phys.circulation", "bio.cell.cell_signal"],
      "description": "先天免疫与适应性免疫；B 细胞与抗体、T 细胞与细胞免疫；疫苗原理。"
    },
    {
      "id": "bio.phys.kidney",
      "name_zh": "肾脏",
      "name_en": "Kidney",
      "depth_level": "K11",
      "prerequisites": ["bio.phys.circulation"],
      "description": "肾单位结构、肾小球滤过、肾小管重吸收与分泌；水盐平衡与酸碱调节。"
    },
    {
      "id": "bio.phys.muscle",
      "name_zh": "肌肉",
      "name_en": "Muscle",
      "depth_level": "K9",
      "prerequisites": ["bio.phys.nervous"],
      "description": "骨骼肌、平滑肌、心肌；肌节、肌动—肌球蛋白滑动学说与肌肉收缩机制。"
    },

    {
      "id": "bio.neuro.neuron",
      "name_zh": "神经元结构",
      "name_en": "Neuron Structure",
      "depth_level": "K11",
      "prerequisites": ["bio.phys.nervous"],
      "description": "神经元胞体、树突、轴突与髓鞘；神经胶质细胞的支持与营养作用。"
    },
    {
      "id": "bio.neuro.synapse",
      "name_zh": "突触",
      "name_en": "Synapse",
      "depth_level": "K11",
      "prerequisites": ["bio.neuro.neuron", "bio.cell.cell_signal"],
      "description": "化学突触与电突触；神经递质释放、受体激活与突触可塑性。"
    },
    {
      "id": "bio.neuro.action_potential",
      "name_zh": "动作电位",
      "name_en": "Action Potential",
      "depth_level": "K11",
      "prerequisites": ["bio.neuro.neuron", "bio.cell.membrane"],
      "description": "钠钾泵静息电位；阈值、去极化、复极化、超极化与不应期；全或无定律。"
    },
    {
      "id": "bio.neuro.brain_lobes",
      "name_zh": "脑分区",
      "name_en": "Brain Lobes",
      "depth_level": "K11",
      "prerequisites": ["bio.neuro.neuron"],
      "description": "额叶、顶叶、颞叶、枕叶分工；小脑、脑干、边缘系统与功能定位。"
    },
    {
      "id": "bio.neuro.eeg_basic",
      "name_zh": "EEG 基础",
      "name_en": "EEG Basics",
      "depth_level": "K13",
      "prerequisites": ["bio.neuro.action_potential", "bio.neuro.brain_lobes"],
      "description": "头皮电极记录皮层群体电活动；alpha/beta/theta/delta 频段与状态判读。"
    },
    {
      "id": "bio.neuro.bci",
      "name_zh": "脑机接口",
      "name_en": "Brain-Computer Interface",
      "depth_level": "K13",
      "prerequisites": ["bio.neuro.eeg_basic", "bio.neuro.synapse"],
      "description": "侵入与非侵入式 BCI；信号采集—特征提取—模式识别—控制反馈闭环。"
    },

    {
      "id": "bio.mol.enzyme",
      "name_zh": "酶",
      "name_en": "Enzyme",
      "depth_level": "K11",
      "prerequisites": ["bio.cell.protein_synthesis"],
      "description": "酶是生物催化剂；活性中心、底物特异性、米氏方程与抑制剂分类。"
    },
    {
      "id": "bio.mol.metabolism",
      "name_zh": "代谢",
      "name_en": "Metabolism",
      "depth_level": "K11",
      "prerequisites": ["bio.mol.enzyme", "bio.cell.organelle"],
      "description": "分解代谢与合成代谢；糖酵解、三羧酸循环、氧化磷酸化与 ATP 产能。"
    },
    {
      "id": "bio.mol.protein_fold",
      "name_zh": "蛋白质折叠",
      "name_en": "Protein Folding",
      "depth_level": "K13",
      "prerequisites": ["bio.mol.enzyme"],
      "description": "一二三四级结构；疏水核心驱动折叠；分子伴侣与错误折叠相关疾病。"
    },
    {
      "id": "bio.mol.alphafold",
      "name_zh": "AlphaFold 结构预测",
      "name_en": "AlphaFold Structure Prediction",
      "depth_level": "K13",
      "prerequisites": ["bio.mol.protein_fold"],
      "description": "DeepMind AlphaFold2 用深度学习从序列预测蛋白质三维结构；CASP 突破与应用。"
    }
  ]
}
