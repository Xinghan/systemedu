{
  "id": "eng",
  "name_zh": "工程",
  "name_en": "Engineering",
  "color": "#8B7A4C",
  "nodes": [
    {
      "id": "eng.mech.simple_machine",
      "name_zh": "简单机械",
      "name_en": "Simple Machines",
      "depth_level": "K3",
      "prerequisites": [],
      "description": "杠杆、滑轮、斜面、轮轴、楔、螺旋六大简单机械，理解通过力臂或斜面长度换取省力的基本原理。"
    },
    {
      "id": "eng.mech.gear_pulley",
      "name_zh": "齿轮与滑轮组",
      "name_en": "Gears and Pulley Systems",
      "depth_level": "K7",
      "prerequisites": ["eng.mech.simple_machine"],
      "description": "齿轮齿数比决定转速与扭矩转换，定滑轮改变力方向、动滑轮省力，组合滑轮组实现机械增益。"
    },
    {
      "id": "eng.mech.bearing",
      "name_zh": "轴承",
      "name_en": "Bearings",
      "depth_level": "K9",
      "prerequisites": ["eng.mech.gear_pulley"],
      "description": "滚动轴承与滑动轴承通过滚珠或润滑膜显著降低旋转摩擦，理解径向/轴向载荷与轴承选型的关系。"
    },
    {
      "id": "eng.mech.cam_linkage",
      "name_zh": "凸轮与连杆",
      "name_en": "Cams and Linkages",
      "depth_level": "K11",
      "prerequisites": ["eng.mech.gear_pulley"],
      "description": "凸轮把旋转运动转换为往复运动，四连杆机构产生复杂轨迹，是机械手、内燃机配气等的核心运动机构。"
    },
    {
      "id": "eng.mech.gearbox",
      "name_zh": "变速箱",
      "name_en": "Gearbox",
      "depth_level": "K11",
      "prerequisites": ["eng.mech.gear_pulley", "eng.mech.bearing"],
      "description": "多级齿轮组合实现多档传动比，平衡功率、转速与扭矩，理解行星齿轮、手动/自动变速的结构差异。"
    },
    {
      "id": "eng.mech.cad_basic",
      "name_zh": "CAD 入门",
      "name_en": "CAD Basics",
      "depth_level": "K11",
      "prerequisites": [],
      "description": "用计算机辅助设计软件（Fusion 360、SolidWorks 等）进行 2D 草图、3D 拉伸、装配与工程图标注的基本操作。"
    },
    {
      "id": "eng.mat.metal",
      "name_zh": "金属材料",
      "name_en": "Metals",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "钢、铝、铜、钛等常见金属的强度、密度、加工性差异，理解合金化与热处理对性能的影响。"
    },
    {
      "id": "eng.mat.plastic_polymer",
      "name_zh": "塑料与聚合物",
      "name_en": "Plastics and Polymers",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "热塑性塑料（PLA、ABS、PET）与热固性塑料的分子链结构差异，决定可重熔性、强度与耐温性。"
    },
    {
      "id": "eng.mat.material_property",
      "name_zh": "材料性能",
      "name_en": "Material Properties",
      "depth_level": "K9",
      "prerequisites": ["eng.mat.metal", "eng.mat.plastic_polymer"],
      "description": "强度、刚度、韧性、硬度、疲劳寿命等关键力学指标，通过应力-应变曲线理解弹性区、屈服点与断裂行为。"
    },
    {
      "id": "eng.mat.3d_printing",
      "name_zh": "3D 打印",
      "name_en": "3D Printing",
      "depth_level": "K9",
      "prerequisites": ["eng.mat.plastic_polymer"],
      "description": "FDM、SLA、SLS 等增材制造工艺，分层堆叠材料构建复杂几何，理解层厚、填充率、支撑结构对成品的影响。"
    },
    {
      "id": "eng.mat.composite",
      "name_zh": "复合材料",
      "name_en": "Composite Materials",
      "depth_level": "K11",
      "prerequisites": ["eng.mat.material_property"],
      "description": "纤维（碳纤维、玻璃纤维）+ 基体（树脂）组合实现轻量化高强度，理解铺层方向对各向异性力学性能的影响。"
    },
    {
      "id": "eng.mat.corrosion",
      "name_zh": "腐蚀",
      "name_en": "Corrosion",
      "depth_level": "K11",
      "prerequisites": ["eng.mat.metal"],
      "description": "金属在电化学环境中发生氧化失效，理解原电池腐蚀、缝隙腐蚀、应力腐蚀，以及涂层、阴极保护等防护策略。"
    },
    {
      "id": "eng.ctrl.feedback_loop",
      "name_zh": "反馈回路",
      "name_en": "Feedback Loop",
      "depth_level": "K9",
      "prerequisites": [],
      "description": "测量当前状态与目标比较产生误差，驱动执行器修正，理解开环 vs 闭环、正反馈 vs 负反馈的稳定性差异。"
    },
    {
      "id": "eng.ctrl.actuator",
      "name_zh": "执行器",
      "name_en": "Actuators",
      "depth_level": "K9",
      "prerequisites": [],
      "description": "电机（直流/步进/伺服）、舵机、气缸、液压等执行器把控制信号转换为机械运动，理解扭矩-转速曲线与选型。"
    },
    {
      "id": "eng.ctrl.system_modeling",
      "name_zh": "系统建模",
      "name_en": "System Modeling",
      "depth_level": "K11",
      "prerequisites": ["eng.ctrl.feedback_loop"],
      "description": "用微分方程、传递函数或状态空间描述动态系统，识别一阶/二阶系统的时间常数、阻尼比与自然频率。"
    },
    {
      "id": "eng.ctrl.pid",
      "name_zh": "PID 控制",
      "name_en": "PID Control",
      "depth_level": "K13",
      "prerequisites": ["eng.ctrl.feedback_loop", "eng.ctrl.system_modeling"],
      "description": "比例(P) + 积分(I) + 微分(D) 三项组合调节误差，理解 Ziegler-Nichols 整定法与超调、稳态误差的权衡。"
    },
    {
      "id": "eng.ctrl.sensor_fusion",
      "name_zh": "传感器融合",
      "name_en": "Sensor Fusion",
      "depth_level": "K13",
      "prerequisites": ["eng.ctrl.system_modeling"],
      "description": "用卡尔曼滤波或互补滤波综合多个噪声传感器（如 IMU + GPS）得到更准确的状态估计，是无人机和自动驾驶的基础。"
    },
    {
      "id": "eng.mfg.assembly_line",
      "name_zh": "装配线",
      "name_en": "Assembly Line",
      "depth_level": "K9",
      "prerequisites": [],
      "description": "把复杂产品拆解为顺序工位的流水线生产，理解节拍时间、瓶颈工位与精益生产中的浪费消除。"
    },
    {
      "id": "eng.mfg.quality_control",
      "name_zh": "质量控制",
      "name_en": "Quality Control",
      "depth_level": "K9",
      "prerequisites": ["eng.mfg.assembly_line"],
      "description": "抽样检测、统计过程控制（SPC）、六西格玛方法监控生产过程波动，理解控制图与过程能力指数 Cpk。"
    },
    {
      "id": "eng.mfg.cnc",
      "name_zh": "CNC 数控加工",
      "name_en": "CNC Machining",
      "depth_level": "K11",
      "prerequisites": ["eng.mech.cad_basic"],
      "description": "计算机数控机床按 G 代码执行铣削/车削，理解坐标系、刀具路径、进给速度与材料切削参数的关系。"
    },
    {
      "id": "eng.mfg.injection_mold",
      "name_zh": "注塑成型",
      "name_en": "Injection Molding",
      "depth_level": "K11",
      "prerequisites": ["eng.mat.plastic_polymer"],
      "description": "熔融塑料高压注入模具型腔冷却成型，理解模具结构（流道、浇口、顶出）与缩痕、翘曲等缺陷的成因。"
    },
    {
      "id": "eng.mfg.laser_cutting",
      "name_zh": "激光切割",
      "name_en": "Laser Cutting",
      "depth_level": "K11",
      "prerequisites": [],
      "description": "高能激光束熔化/汽化材料实现精密切割，理解功率、速度、辅助气体对切口质量与切割深度的影响。"
    },
    {
      "id": "eng.design.process",
      "name_zh": "工程设计流程",
      "name_en": "Engineering Design Process",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "定义问题 → 调研 → 头脑风暴 → 原型 → 测试 → 迭代的循环方法论，是所有工程项目的元流程。"
    },
    {
      "id": "eng.design.iteration_prototype",
      "name_zh": "迭代原型",
      "name_en": "Iterative Prototyping",
      "depth_level": "K7",
      "prerequisites": ["eng.design.process"],
      "description": "用低保真到高保真原型快速验证假设，理解失败是设计的常态、每次迭代都聚焦一个核心不确定性。"
    },
    {
      "id": "eng.design.tolerance",
      "name_zh": "公差",
      "name_en": "Tolerance",
      "depth_level": "K11",
      "prerequisites": ["eng.design.process"],
      "description": "尺寸允许的偏差范围，理解配合（间隙/过盈/过渡）、几何公差（GD&T）与公差堆叠对装配可靠性的影响。"
    },
    {
      "id": "eng.design.fmea",
      "name_zh": "故障模式分析",
      "name_en": "Failure Mode and Effects Analysis",
      "depth_level": "K13",
      "prerequisites": ["eng.design.process"],
      "description": "系统性列出可能失效模式，按严重度 × 发生率 × 探测难度计算 RPN，识别高风险点并制定预防措施。"
    },
    {
      "id": "eng.robo.kinematics",
      "name_zh": "机器人运动学",
      "name_en": "Robot Kinematics",
      "depth_level": "K11",
      "prerequisites": [],
      "description": "用 DH 参数描述串联关节链，正运动学求末端位姿，逆运动学求关节角度，理解奇异点与工作空间。"
    },
    {
      "id": "eng.robo.arm",
      "name_zh": "机械臂",
      "name_en": "Robotic Arm",
      "depth_level": "K11",
      "prerequisites": ["eng.robo.kinematics"],
      "description": "6 自由度工业机械臂结构（基座/肩/肘/腕），理解关节驱动、末端执行器选型与轨迹规划。"
    },
    {
      "id": "eng.robo.mobile",
      "name_zh": "移动机器人",
      "name_en": "Mobile Robots",
      "depth_level": "K11",
      "prerequisites": [],
      "description": "差速驱动、阿克曼转向、全向轮等底盘运动模型，理解里程计推算与轮式打滑误差。"
    },
    {
      "id": "eng.robo.slam",
      "name_zh": "SLAM",
      "name_en": "Simultaneous Localization and Mapping",
      "depth_level": "K13",
      "prerequisites": ["eng.robo.mobile", "eng.ctrl.sensor_fusion"],
      "description": "机器人在未知环境中同时构建地图并定位自身，理解激光 SLAM、视觉 SLAM 与回环检测的核心思想。"
    }
  ]
}
