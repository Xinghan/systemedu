{
  "id": "geo",
  "name_zh": "地质",
  "name_en": "Geology",
  "color": "#A57959",
  "nodes": [
    {
      "id": "geo.earth.layers",
      "name_zh": "地球内部分层",
      "name_en": "Earth's Internal Layers",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "地球由地壳、地幔、地核三大圈层构成；通过地震波传播速度变化推断各层物质状态与边界。"
    },
    {
      "id": "geo.earth.crust",
      "name_zh": "地壳",
      "name_en": "Crust",
      "depth_level": "K7",
      "prerequisites": ["geo.earth.layers"],
      "description": "地壳分大陆地壳（花岗质）与大洋地壳（玄武质）；厚度 5-70 km，硅铝/硅镁层组成。"
    },
    {
      "id": "geo.earth.mantle",
      "name_zh": "地幔",
      "name_en": "Mantle",
      "depth_level": "K9",
      "prerequisites": ["geo.earth.layers"],
      "description": "地幔占地球体积 84%；上地幔软流圈塑性流动驱动板块运动；下地幔高压高温固态。"
    },
    {
      "id": "geo.earth.core",
      "name_zh": "地核",
      "name_en": "Core",
      "depth_level": "K11",
      "prerequisites": ["geo.earth.layers"],
      "description": "外核液态铁镍流动产生地磁场（发电机效应）；内核固态铁镍，温度近似太阳表面。"
    },
    {
      "id": "geo.plate.theory",
      "name_zh": "板块构造理论",
      "name_en": "Plate Tectonics Theory",
      "depth_level": "K7",
      "prerequisites": ["geo.earth.mantle"],
      "description": "魏格纳大陆漂移到板块构造的演进；岩石圈划分为约 15 个板块，骑在软流圈上漂移。"
    },
    {
      "id": "geo.plate.boundary",
      "name_zh": "板块边界",
      "name_en": "Plate Boundaries",
      "depth_level": "K9",
      "prerequisites": ["geo.plate.theory"],
      "description": "汇聚型（俯冲/碰撞）、离散型（洋中脊）、转换型（圣安德烈斯断层）三类边界与典型构造。"
    },
    {
      "id": "geo.plate.earthquake",
      "name_zh": "地震",
      "name_en": "Earthquake",
      "depth_level": "K7",
      "prerequisites": ["geo.plate.boundary"],
      "description": "震源、震中、震级与烈度；P 波 S 波 L 波传播特性；环太平洋地震带分布规律。"
    },
    {
      "id": "geo.plate.volcano",
      "name_zh": "火山",
      "name_en": "Volcano",
      "depth_level": "K7",
      "prerequisites": ["geo.plate.boundary"],
      "description": "盾状、复合、火山碎屑锥三种类型；岩浆成分决定喷发剧烈度；热点火山与板块边界火山。"
    },
    {
      "id": "geo.plate.mountain_formation",
      "name_zh": "山脉形成",
      "name_en": "Mountain Formation",
      "depth_level": "K9",
      "prerequisites": ["geo.plate.boundary"],
      "description": "造山运动机制：大陆碰撞（喜马拉雅）、俯冲带（安第斯）、地堑断块山（华山）三类。"
    },
    {
      "id": "geo.rock.types",
      "name_zh": "岩石三大类",
      "name_en": "Three Rock Types",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "岩石按成因分为火成岩、沉积岩、变质岩；岩石循环将三类岩石相互转化。"
    },
    {
      "id": "geo.rock.igneous",
      "name_zh": "火成岩",
      "name_en": "Igneous Rock",
      "depth_level": "K7",
      "prerequisites": ["geo.rock.types"],
      "description": "岩浆冷凝结晶形成；侵入岩（花岗岩）粗粒、喷出岩（玄武岩）细粒；矿物组成与酸碱性。"
    },
    {
      "id": "geo.rock.sedimentary",
      "name_zh": "沉积岩",
      "name_en": "Sedimentary Rock",
      "depth_level": "K7",
      "prerequisites": ["geo.rock.types"],
      "description": "碎屑岩（砂岩、页岩）、化学岩（石灰岩）、生物岩（煤）；层理、化石与沉积环境判读。"
    },
    {
      "id": "geo.rock.metamorphic",
      "name_zh": "变质岩",
      "name_en": "Metamorphic Rock",
      "depth_level": "K9",
      "prerequisites": ["geo.rock.igneous", "geo.rock.sedimentary"],
      "description": "原岩在高温高压下重结晶；接触变质（大理岩）与区域变质（片岩、片麻岩）；变质相系。"
    },
    {
      "id": "geo.paleo.fossil",
      "name_zh": "化石",
      "name_en": "Fossil",
      "depth_level": "K5",
      "prerequisites": ["geo.rock.sedimentary"],
      "description": "化石形成条件：快速埋藏、缺氧、矿化；体化石、遗迹化石、模铸化石与琥珀。"
    },
    {
      "id": "geo.paleo.dinosaur",
      "name_zh": "恐龙",
      "name_en": "Dinosaur",
      "depth_level": "K3",
      "prerequisites": [],
      "description": "恐龙生活于三叠—白垩纪（约 2.3 亿—6600 万年前）；蜥臀目与鸟臀目分类与典型代表。"
    },
    {
      "id": "geo.paleo.extinction",
      "name_zh": "大灭绝事件",
      "name_en": "Mass Extinction",
      "depth_level": "K9",
      "prerequisites": ["geo.paleo.fossil"],
      "description": "地史五次大灭绝：奥陶末、泥盆末、二叠末、三叠末、白垩末；K-Pg 小行星撞击假说。"
    },
    {
      "id": "geo.paleo.timescale",
      "name_zh": "地质年代表",
      "name_en": "Geological Time Scale",
      "depth_level": "K9",
      "prerequisites": ["geo.paleo.fossil"],
      "description": "宙—代—纪—世划分；46 亿年地球史压缩为一年的尺度感；放射性同位素测年方法。"
    },
    {
      "id": "geo.erosion.weathering",
      "name_zh": "风化",
      "name_en": "Weathering",
      "depth_level": "K7",
      "prerequisites": ["geo.rock.types"],
      "description": "物理风化（冻融、剥落）、化学风化（溶解、氧化、水解）与生物风化的协同作用。"
    },
    {
      "id": "geo.erosion.river_erosion",
      "name_zh": "河流侵蚀",
      "name_en": "River Erosion",
      "depth_level": "K7",
      "prerequisites": ["geo.erosion.weathering"],
      "description": "下蚀、侧蚀、溯源侵蚀三种方式；V 型谷、曲流、牛轭湖与三角洲的形成机制。"
    },
    {
      "id": "geo.erosion.glacier",
      "name_zh": "冰川作用",
      "name_en": "Glacial Action",
      "depth_level": "K9",
      "prerequisites": ["geo.erosion.weathering"],
      "description": "山岳冰川与大陆冰川；冰斗、角峰、U 型谷、冰碛物等冰蚀冰积地貌特征。"
    },
    {
      "id": "geo.erosion.soil_formation",
      "name_zh": "土壤形成",
      "name_en": "Soil Formation",
      "depth_level": "K7",
      "prerequisites": ["geo.erosion.weathering"],
      "description": "母岩—风化—腐殖质积累—土壤剖面（O/A/B/C 层）；气候、生物、时间五大成土因素。"
    },
    {
      "id": "geo.res.fossil_fuel",
      "name_zh": "化石燃料",
      "name_en": "Fossil Fuel",
      "depth_level": "K7",
      "prerequisites": ["geo.rock.sedimentary"],
      "description": "煤、石油、天然气来源于古生物遗体；生油层—储集层—盖层成藏组合；不可再生性。"
    },
    {
      "id": "geo.res.mining",
      "name_zh": "采矿",
      "name_en": "Mining",
      "depth_level": "K9",
      "prerequisites": ["geo.rock.igneous", "geo.rock.metamorphic"],
      "description": "露天开采与地下开采；矿床类型（岩浆、热液、沉积）；尾矿处理与生态修复。"
    },
    {
      "id": "geo.res.groundwater",
      "name_zh": "地下水",
      "name_en": "Groundwater",
      "depth_level": "K9",
      "prerequisites": ["geo.erosion.soil_formation"],
      "description": "含水层、隔水层、潜水与承压水；地下水循环与喀斯特地貌；过度开采引发地面沉降。"
    },
    {
      "id": "geo.res.rare_earth",
      "name_zh": "稀土元素",
      "name_en": "Rare Earth Elements",
      "depth_level": "K11",
      "prerequisites": ["geo.res.mining"],
      "description": "镧系 15 元素加 Sc、Y 共 17 种；离子吸附型矿与碳酸岩型矿；新能源磁体核心原料。"
    }
  ]
}
