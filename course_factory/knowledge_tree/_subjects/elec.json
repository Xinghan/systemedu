{
  "id": "elec",
  "name_zh": "电子电路",
  "name_en": "Electronics",
  "color": "#A68DFF",
  "nodes": [
    {
      "id": "elec.circ.current_voltage",
      "name_zh": "电流与电压",
      "name_en": "Current and Voltage",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "电荷、电流方向与大小、电势差与电压、安培和伏特单位"
    },
    {
      "id": "elec.circ.resistor",
      "name_zh": "电阻与色环",
      "name_en": "Resistor and Color Code",
      "depth_level": "K7",
      "prerequisites": ["elec.circ.current_voltage"],
      "description": "电阻定义与阻值、4 环 5 环色环识别、常见封装"
    },
    {
      "id": "elec.circ.ohm_law",
      "name_zh": "欧姆定律",
      "name_en": "Ohm's Law",
      "depth_level": "K7",
      "prerequisites": ["elec.circ.current_voltage", "elec.circ.resistor"],
      "description": "U=IR 三量关系、伏安特性曲线、限流电阻计算"
    },
    {
      "id": "elec.circ.series_parallel",
      "name_zh": "串联与并联",
      "name_en": "Series and Parallel Circuits",
      "depth_level": "K7",
      "prerequisites": ["elec.circ.ohm_law"],
      "description": "串并联电路的电流电压分配、等效电阻、混联分析"
    },
    {
      "id": "elec.circ.breadboard",
      "name_zh": "面包板使用",
      "name_en": "Breadboard Prototyping",
      "depth_level": "K7",
      "prerequisites": ["elec.circ.series_parallel"],
      "description": "面包板孔位连接规则、跳线、电源轨、常见接线错误排查"
    },
    {
      "id": "elec.circ.multimeter",
      "name_zh": "万用表测量",
      "name_en": "Multimeter Usage",
      "depth_level": "K7",
      "prerequisites": ["elec.circ.ohm_law"],
      "description": "万用表档位、直流电压电流电阻测量、通断检测、安全操作"
    },
    {
      "id": "elec.circ.kirchhoff",
      "name_zh": "基尔霍夫定律",
      "name_en": "Kirchhoff's Laws",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.series_parallel"],
      "description": "KCL 节点电流定律、KVL 回路电压定律、复杂网络方程求解"
    },
    {
      "id": "elec.circ.power",
      "name_zh": "电功率",
      "name_en": "Electric Power",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.ohm_law"],
      "description": "P=UI 功率公式、焦耳热、瓦特单位、电阻额定功率与散热"
    },
    {
      "id": "elec.comp.capacitor",
      "name_zh": "电容",
      "name_en": "Capacitor",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.power"],
      "description": "电容定义与法拉单位、充放电曲线、滤波与储能、电解陶瓷分类"
    },
    {
      "id": "elec.comp.diode_led",
      "name_zh": "二极管与 LED",
      "name_en": "Diode and LED",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.power"],
      "description": "PN 结单向导通、压降、整流、LED 限流电阻设计"
    },
    {
      "id": "elec.comp.relay_switch",
      "name_zh": "继电器与开关",
      "name_en": "Relay and Switch",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.power"],
      "description": "机械开关类型、继电器原理、强弱电隔离、续流二极管"
    },
    {
      "id": "elec.comp.inductor",
      "name_zh": "电感",
      "name_en": "Inductor",
      "depth_level": "K11",
      "prerequisites": ["elec.comp.capacitor"],
      "description": "电感定义与亨利单位、自感与互感、LC 振荡、滤波扼流应用"
    },
    {
      "id": "elec.comp.transistor",
      "name_zh": "三极管",
      "name_en": "Transistor (BJT/MOSFET)",
      "depth_level": "K11",
      "prerequisites": ["elec.comp.diode_led"],
      "description": "BJT/MOSFET 结构、放大与开关两种工作模式、基本偏置电路"
    },
    {
      "id": "elec.comp.op_amp",
      "name_zh": "运算放大器",
      "name_en": "Operational Amplifier",
      "depth_level": "K13",
      "prerequisites": ["elec.comp.transistor"],
      "description": "虚短虚断、反相同相放大、跟随器、比较器、典型应用电路"
    },
    {
      "id": "elec.digital.binary_hex",
      "name_zh": "二进制与十六进制",
      "name_en": "Binary and Hexadecimal",
      "depth_level": "K9",
      "prerequisites": [],
      "description": "二进制十六进制表示、进制转换、补码、字节与位"
    },
    {
      "id": "elec.digital.logic_gate",
      "name_zh": "逻辑门",
      "name_en": "Logic Gates",
      "depth_level": "K11",
      "prerequisites": ["elec.digital.binary_hex"],
      "description": "与或非门、异或、布尔代数、真值表、组合逻辑设计"
    },
    {
      "id": "elec.digital.flip_flop",
      "name_zh": "触发器",
      "name_en": "Flip-Flops",
      "depth_level": "K11",
      "prerequisites": ["elec.digital.logic_gate"],
      "description": "RS/D/JK 触发器、时钟边沿触发、寄存器单元、时序逻辑入门"
    },
    {
      "id": "elec.digital.counter",
      "name_zh": "计数器",
      "name_en": "Counter",
      "depth_level": "K11",
      "prerequisites": ["elec.digital.flip_flop"],
      "description": "异步同步计数器、分频器、模 N 计数、典型 74 系列芯片"
    },
    {
      "id": "elec.digital.adc_dac",
      "name_zh": "ADC 与 DAC",
      "name_en": "ADC and DAC",
      "depth_level": "K13",
      "prerequisites": ["elec.digital.counter", "elec.comp.op_amp"],
      "description": "采样定理、量化误差、SAR/Sigma-Delta ADC、R-2R DAC、分辨率与采样率"
    },
    {
      "id": "elec.signal.analog",
      "name_zh": "模拟信号",
      "name_en": "Analog Signal",
      "depth_level": "K11",
      "prerequisites": ["elec.comp.capacitor"],
      "description": "时域波形、频率幅值相位、正弦信号、放大与衰减"
    },
    {
      "id": "elec.signal.digital_signal",
      "name_zh": "数字信号",
      "name_en": "Digital Signal",
      "depth_level": "K11",
      "prerequisites": ["elec.digital.binary_hex", "elec.signal.analog"],
      "description": "高低电平、上升下降沿、时钟周期、占空比、电平标准 (TTL/CMOS)"
    },
    {
      "id": "elec.signal.pwm",
      "name_zh": "PWM 脉宽调制",
      "name_en": "PWM (Pulse Width Modulation)",
      "depth_level": "K11",
      "prerequisites": ["elec.signal.digital_signal"],
      "description": "占空比与等效电压、PWM 调光调速、舵机控制、频率选择"
    },
    {
      "id": "elec.signal.noise",
      "name_zh": "噪声与信噪比",
      "name_en": "Noise and SNR",
      "depth_level": "K13",
      "prerequisites": ["elec.signal.analog"],
      "description": "热噪声/散粒噪声/工频干扰、信噪比 SNR、滤波与屏蔽降噪策略"
    },
    {
      "id": "elec.comm.gpio",
      "name_zh": "GPIO 引脚",
      "name_en": "GPIO Pins",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.breadboard"],
      "description": "通用输入输出口、上拉下拉电阻、推挽开漏、引脚复用"
    },
    {
      "id": "elec.comm.usb_basic",
      "name_zh": "USB 基础",
      "name_en": "USB Basics",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.power"],
      "description": "USB 接口类型 (A/B/C/Micro)、5V 供电、数据线 D+/D-、常见枚举过程"
    },
    {
      "id": "elec.comm.wifi_basic",
      "name_zh": "WiFi 基础",
      "name_en": "WiFi Basics",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.power"],
      "description": "2.4G/5G 频段、AP/STA 模式、SSID 密码、IoT 模组 (ESP8266/ESP32) 连接"
    },
    {
      "id": "elec.comm.uart",
      "name_zh": "UART 串口",
      "name_en": "UART Serial",
      "depth_level": "K11",
      "prerequisites": ["elec.signal.digital_signal", "elec.comm.gpio"],
      "description": "异步串口协议、波特率、起始位停止位校验位、TX/RX 接线 (典型 PMS5003)"
    },
    {
      "id": "elec.comm.i2c",
      "name_zh": "I2C 总线",
      "name_en": "I2C Bus",
      "depth_level": "K11",
      "prerequisites": ["elec.signal.digital_signal", "elec.comm.gpio"],
      "description": "SDA/SCL 两线、主从地址、上拉电阻、读写时序 (典型 BME280)"
    },
    {
      "id": "elec.comm.spi",
      "name_zh": "SPI 总线",
      "name_en": "SPI Bus",
      "depth_level": "K11",
      "prerequisites": ["elec.signal.digital_signal", "elec.comm.gpio"],
      "description": "MOSI/MISO/SCLK/CS 四线、全双工、时钟极性相位 CPOL/CPHA、菊花链"
    },
    {
      "id": "elec.embed.rpi_basic",
      "name_zh": "Raspberry Pi 入门",
      "name_en": "Raspberry Pi Basics",
      "depth_level": "K9",
      "prerequisites": ["elec.comm.gpio"],
      "description": "Pi 硬件构成、Raspberry Pi OS 安装、SSH 远程、GPIO 控制 LED"
    },
    {
      "id": "elec.embed.mcu_basic",
      "name_zh": "MCU 基础",
      "name_en": "Microcontroller Basics (Arduino/STM32)",
      "depth_level": "K11",
      "prerequisites": ["elec.comm.gpio", "elec.signal.pwm"],
      "description": "MCU 架构、寄存器/外设、Arduino IDE 与 STM32 HAL、最小系统设计"
    },
    {
      "id": "elec.embed.firmware",
      "name_zh": "固件",
      "name_en": "Firmware",
      "depth_level": "K11",
      "prerequisites": ["elec.embed.mcu_basic"],
      "description": "Bootloader、固件烧录、OTA 升级、固件版本管理与回滚"
    },
    {
      "id": "elec.embed.rtos",
      "name_zh": "实时操作系统",
      "name_en": "Real-Time Operating System (RTOS)",
      "depth_level": "K13",
      "prerequisites": ["elec.embed.firmware"],
      "description": "FreeRTOS 任务调度、信号量与队列、优先级反转、实时性指标"
    },
    {
      "id": "elec.sensor.principle",
      "name_zh": "传感器原理",
      "name_en": "Sensor Principles (Transduction)",
      "depth_level": "K9",
      "prerequisites": ["elec.circ.power"],
      "description": "传感器换能原理 (光/热/力/化学转电信号)、模拟与数字输出、常见类型"
    },
    {
      "id": "elec.sensor.calibration",
      "name_zh": "传感器标定",
      "name_en": "Sensor Calibration",
      "depth_level": "K11",
      "prerequisites": ["elec.sensor.principle", "elec.signal.noise"],
      "description": "零点校准、量程标定、参考标准、线性化与温度补偿、漂移评估"
    }
  ]
}
