{
  "id": "chem",
  "name_zh": "化学",
  "name_en": "Chemistry",
  "color": "#E8A07C",
  "nodes": [
    {
      "id": "chem.atom.basic",
      "name_zh": "原子分子基础",
      "name_en": "Atoms and Molecules",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "物质由原子构成，原子结合形成分子，理解元素、化合物与混合物的区别，建立微观物质观。"
    },
    {
      "id": "chem.atom.periodic_table",
      "name_zh": "元素周期表",
      "name_en": "Periodic Table",
      "depth_level": "K7",
      "prerequisites": ["chem.atom.basic"],
      "description": "元素按原子序数排列，周期与族反映性质规律，理解金属、非金属与稀有气体分区。"
    },
    {
      "id": "chem.atom.electron_shell",
      "name_zh": "电子层",
      "name_en": "Electron Shells",
      "depth_level": "K9",
      "prerequisites": ["chem.atom.periodic_table"],
      "description": "电子分层排布于 K、L、M 等壳层，最外层电子数决定化学性质，引出 2-8-8 规则。"
    },
    {
      "id": "chem.atom.isotope",
      "name_zh": "同位素",
      "name_en": "Isotopes",
      "depth_level": "K9",
      "prerequisites": ["chem.atom.basic"],
      "description": "质子数相同、中子数不同的原子为同位素，理解相对原子质量加权平均与放射性同位素应用。"
    },
    {
      "id": "chem.atom.ion",
      "name_zh": "离子",
      "name_en": "Ions",
      "depth_level": "K9",
      "prerequisites": ["chem.atom.electron_shell"],
      "description": "原子得失电子形成阳离子或阴离子，理解离子电荷与最外层电子数关系，为离子键铺垫。"
    },
    {
      "id": "chem.atom.molar_mass",
      "name_zh": "摩尔质量",
      "name_en": "Molar Mass",
      "depth_level": "K9",
      "prerequisites": ["chem.atom.basic", "chem.atom.periodic_table"],
      "description": "摩尔是物质的量单位，阿伏伽德罗常数 6.02×10²³，摩尔质量数值等于相对分子质量。"
    },
    {
      "id": "chem.bond.ionic",
      "name_zh": "离子键",
      "name_en": "Ionic Bond",
      "depth_level": "K9",
      "prerequisites": ["chem.atom.ion"],
      "description": "阴阳离子通过静电吸引形成离子键，典型如 NaCl 晶体，理解高熔点与水溶导电特性。"
    },
    {
      "id": "chem.bond.covalent",
      "name_zh": "共价键",
      "name_en": "Covalent Bond",
      "depth_level": "K9",
      "prerequisites": ["chem.atom.electron_shell"],
      "description": "原子通过共用电子对形成共价键，区分单键、双键、三键，理解极性与非极性键的电负性差异。"
    },
    {
      "id": "chem.bond.metallic",
      "name_zh": "金属键",
      "name_en": "Metallic Bond",
      "depth_level": "K11",
      "prerequisites": ["chem.bond.ionic", "chem.bond.covalent"],
      "description": "金属原子共享自由电子海，解释延展性、导电导热与金属光泽的微观成因。"
    },
    {
      "id": "chem.bond.molecular_geometry",
      "name_zh": "分子几何 VSEPR",
      "name_en": "Molecular Geometry VSEPR",
      "depth_level": "K11",
      "prerequisites": ["chem.bond.covalent"],
      "description": "价层电子对互斥理论预测分子形状，掌握直线、三角形、四面体、弯曲等典型构型与键角。"
    },
    {
      "id": "chem.rxn.equation",
      "name_zh": "化学方程式",
      "name_en": "Chemical Equation",
      "depth_level": "K7",
      "prerequisites": ["chem.atom.basic"],
      "description": "用化学式与系数表达反应物到生成物的转化，理解箭头、状态符号与反应条件的写法。"
    },
    {
      "id": "chem.rxn.balance",
      "name_zh": "配平",
      "name_en": "Balancing Equations",
      "depth_level": "K9",
      "prerequisites": ["chem.rxn.equation", "chem.atom.basic"],
      "description": "依据质量守恒定律配平方程式，掌握观察法与最小公倍数法处理常见无机反应。"
    },
    {
      "id": "chem.rxn.types",
      "name_zh": "反应类型",
      "name_en": "Reaction Types",
      "depth_level": "K9",
      "prerequisites": ["chem.rxn.balance"],
      "description": "区分合成、分解、置换、复分解四大基本反应类型，掌握判别条件与典型实例。"
    },
    {
      "id": "chem.rxn.redox",
      "name_zh": "氧化还原",
      "name_en": "Redox Reactions",
      "depth_level": "K11",
      "prerequisites": ["chem.rxn.types", "chem.atom.electron_shell"],
      "description": "以电子转移定义氧化与还原，掌握化合价升降法判断氧化剂、还原剂与配平。"
    },
    {
      "id": "chem.rxn.acid_base",
      "name_zh": "酸碱",
      "name_en": "Acids and Bases",
      "depth_level": "K9",
      "prerequisites": ["chem.atom.ion"],
      "description": "酸电离出 H⁺，碱电离出 OH⁻，理解中和反应生成盐和水，掌握常见指示剂变色。"
    },
    {
      "id": "chem.rxn.ph",
      "name_zh": "pH 值",
      "name_en": "pH",
      "depth_level": "K9",
      "prerequisites": ["chem.rxn.acid_base"],
      "description": "pH = -lg[H⁺]，0-14 标度衡量酸碱强弱，理解 pH 试纸与常见溶液 pH 范围。"
    },
    {
      "id": "chem.rxn.electrochem",
      "name_zh": "电化学 电池",
      "name_en": "Electrochemistry Cells",
      "depth_level": "K11",
      "prerequisites": ["chem.rxn.redox"],
      "description": "原电池将化学能转电能，电解池反之，理解电极反应、电流方向与锂电池工作原理。"
    },
    {
      "id": "chem.rxn.catalyst",
      "name_zh": "催化剂",
      "name_en": "Catalyst",
      "depth_level": "K11",
      "prerequisites": ["chem.rxn.types"],
      "description": "催化剂改变反应速率但自身不变，理解降低活化能机制与酶、汽车三元催化等实例。"
    },
    {
      "id": "chem.eq.equilibrium",
      "name_zh": "化学平衡",
      "name_en": "Chemical Equilibrium",
      "depth_level": "K11",
      "prerequisites": ["chem.rxn.types", "chem.rxn.catalyst"],
      "description": "可逆反应正逆速率相等时达动态平衡，掌握平衡常数 K 的表达与意义。"
    },
    {
      "id": "chem.eq.le_chatelier",
      "name_zh": "勒沙特列原理",
      "name_en": "Le Chatelier's Principle",
      "depth_level": "K11",
      "prerequisites": ["chem.eq.equilibrium"],
      "description": "改变浓度、压强、温度时平衡向减弱扰动方向移动，应用于合成氨等工业反应优化。"
    },
    {
      "id": "chem.eq.solubility",
      "name_zh": "溶解度",
      "name_en": "Solubility",
      "depth_level": "K11",
      "prerequisites": ["chem.eq.equilibrium"],
      "description": "饱和溶液的溶质浓度即溶解度，理解溶度积 Ksp、温度影响与同离子效应。"
    },
    {
      "id": "chem.eq.thermodynamics",
      "name_zh": "热力学",
      "name_en": "Thermodynamics",
      "depth_level": "K13",
      "prerequisites": ["chem.eq.le_chatelier"],
      "description": "焓变 ΔH、熵变 ΔS、吉布斯自由能 ΔG = ΔH - TΔS 判断反应自发性方向。"
    },
    {
      "id": "chem.org.hydrocarbon",
      "name_zh": "烃",
      "name_en": "Hydrocarbons",
      "depth_level": "K9",
      "prerequisites": ["chem.bond.covalent"],
      "description": "仅含碳氢元素的有机物，区分烷烃、烯烃、炔烃、芳香烃，掌握甲烷、乙烯典型性质。"
    },
    {
      "id": "chem.org.functional_group",
      "name_zh": "官能团",
      "name_en": "Functional Groups",
      "depth_level": "K11",
      "prerequisites": ["chem.org.hydrocarbon"],
      "description": "决定有机物性质的特定原子团，识别 -OH、-COOH、-NH₂、-CHO 等常见官能团。"
    },
    {
      "id": "chem.org.alcohol_acid",
      "name_zh": "醇 酸",
      "name_en": "Alcohols and Carboxylic Acids",
      "depth_level": "K11",
      "prerequisites": ["chem.org.functional_group"],
      "description": "乙醇、乙酸的结构与性质，掌握酯化反应生成乙酸乙酯及消去、氧化等典型转化。"
    },
    {
      "id": "chem.org.polymer",
      "name_zh": "聚合物",
      "name_en": "Polymers",
      "depth_level": "K11",
      "prerequisites": ["chem.org.functional_group"],
      "description": "单体通过加聚或缩聚形成高分子，理解聚乙烯、尼龙、橡胶的结构与性能关系。"
    },
    {
      "id": "chem.org.protein_basic",
      "name_zh": "蛋白质基础",
      "name_en": "Proteins Basics",
      "depth_level": "K11",
      "prerequisites": ["chem.org.alcohol_acid"],
      "description": "氨基酸通过肽键缩合成多肽与蛋白质，理解一级到四级结构与变性现象。"
    },
    {
      "id": "chem.org.dna_chem",
      "name_zh": "DNA 化学",
      "name_en": "DNA Chemistry",
      "depth_level": "K13",
      "prerequisites": ["chem.org.protein_basic", "chem.org.polymer"],
      "description": "核苷酸由磷酸、脱氧核糖、含氮碱基构成，理解双螺旋氢键配对与遗传信息编码。"
    },
    {
      "id": "chem.env.air_composition",
      "name_zh": "空气成分",
      "name_en": "Air Composition",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "空气主要由 78% N₂、21% O₂、约 0.04% CO₂ 及稀有气体组成，理解氧气助燃与氮气稳定性。"
    },
    {
      "id": "chem.env.combustion",
      "name_zh": "燃烧",
      "name_en": "Combustion",
      "depth_level": "K7",
      "prerequisites": ["chem.env.air_composition", "chem.rxn.equation"],
      "description": "可燃物与氧气剧烈氧化放热发光，掌握燃烧三要素与完全/不完全燃烧产物差异。"
    },
    {
      "id": "chem.env.greenhouse_gas",
      "name_zh": "温室气体",
      "name_en": "Greenhouse Gases",
      "depth_level": "K9",
      "prerequisites": ["chem.env.air_composition", "chem.env.combustion"],
      "description": "CO₂、CH₄、N₂O 等吸收红外辐射加剧温室效应，理解化石燃料排放与碳循环失衡。"
    },
    {
      "id": "chem.env.aerosol",
      "name_zh": "气溶胶",
      "name_en": "Aerosols PM2.5",
      "depth_level": "K11",
      "prerequisites": ["chem.env.air_composition", "chem.bond.molecular_geometry"],
      "description": "悬浮在空气中的固液微粒，PM2.5 主要由硫酸盐、硝酸盐、有机碳构成，影响健康与气候。"
    },
    {
      "id": "chem.lab.safety",
      "name_zh": "化学实验安全",
      "name_en": "Lab Safety",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "护目镜、手套、通风橱等防护装备的使用，掌握酸碱稀释、危险品处理与应急冲洗规范。"
    },
    {
      "id": "chem.lab.glassware",
      "name_zh": "玻璃仪器",
      "name_en": "Glassware",
      "depth_level": "K7",
      "prerequisites": ["chem.lab.safety"],
      "description": "试管、烧杯、烧瓶、冷凝管的用途与规格，掌握加热、过滤、蒸馏等基础组装。"
    },
    {
      "id": "chem.lab.measurement",
      "name_zh": "量筒 滴定",
      "name_en": "Measurement and Titration",
      "depth_level": "K7",
      "prerequisites": ["chem.lab.glassware"],
      "description": "量筒读数视线水平于凹液面最低处，滴定通过指示剂变色精确测定未知浓度。"
    }
  ]
}
