    {
      "id": "math.arith.sci_notation",
      "name_zh": "科学计数法",
      "name_en": "Scientific Notation",
      "depth_level": "K7",
      "prerequisites": ["math.arith.power_root", "math.arith.decimal"],
      "description": "用 a×10^n 表示极大极小数、有效数字"
