    {
      "id": "math.algebra.variable",
      "name_zh": "变量与代数式",
      "name_en": "Variables and Expressions",
      "depth_level": "K5",
      "prerequisites": ["math.arith.mult_div"],
      "description": "字母表示数、代数式求值、合并同类项"
    },
    {
      "id": "math.algebra.linear_eq",
      "name_zh": "一元一次方程",
      "name_en": "Linear Equation in One Variable",
