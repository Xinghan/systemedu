      "description": "百分数概念、与分数小数互化、折扣与利率应用"
    },
    {
      "id": "math.arith.ratio_proportion",
      "name_zh": "比与比例",
      "name_en": "Ratio and Proportion",
      "depth_level": "K5",
      "prerequisites": ["math.arith.fraction_ops"],
      "description": "比的意义、化简、正反比例、按比分配"
    },
    {
      "id": "math.arith.power_root",
      "name_zh": "乘方与开方",
      "name_en": "Powers and Roots",
