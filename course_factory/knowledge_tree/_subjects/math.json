      "id": "math.arith.fraction_ops",
      "name_zh": "分数四则",
      "name_en": "Fraction Arithmetic",
      "depth_level": "K5",
      "prerequisites": ["math.arith.fraction_basic"],
      "description": "通分约分、分数加减乘除、混合运算"
