{
  "id": "med",
  "name_zh": "医学",
  "name_en": "Medicine",
  "color": "#E66F88",
  "nodes": [
    {
      "id": "med.anat.body_system_overview",
      "name_zh": "人体系统总览",
      "name_en": "Human Body Systems Overview",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "人体十大系统总览：呼吸、循环、消化、神经、内分泌、免疫、肌骨、泌尿、生殖、皮肤，各系统的核心功能与协同关系。"
    },
    {
      "id": "med.anat.respiratory",
      "name_zh": "呼吸系统解剖",
      "name_en": "Respiratory System Anatomy",
      "depth_level": "K7",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "鼻、咽、喉、气管、支气管、肺泡的结构；气体如何从口鼻进入血液，膈肌与肋间肌如何驱动呼吸。"
    },
    {
      "id": "med.anat.cardiovascular",
      "name_zh": "心血管解剖",
      "name_en": "Cardiovascular Anatomy",
      "depth_level": "K7",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "心脏四腔（左右心房心室）、瓣膜、动脉/静脉/毛细血管；体循环与肺循环的完整路径。"
    },
    {
      "id": "med.anat.digestive",
      "name_zh": "消化系统解剖",
      "name_en": "Digestive System Anatomy",
      "depth_level": "K7",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "从口腔到肛门的消化道全程；胃、小肠、大肠、肝、胰的位置与分工；食物如何被分解吸收。"
    },
    {
      "id": "med.anat.nervous",
      "name_zh": "神经系统解剖",
      "name_en": "Nervous System Anatomy",
      "depth_level": "K9",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "中枢神经系统（脑、脊髓）与周围神经系统；大脑分叶、神经元结构与突触传导基本概念。"
    },
    {
      "id": "med.anat.endocrine",
      "name_zh": "内分泌系统",
      "name_en": "Endocrine System",
      "depth_level": "K11",
      "prerequisites": ["med.anat.body_system_overview", "med.anat.nervous"],
      "description": "下丘脑、垂体、甲状腺、肾上腺、胰岛、性腺等主要内分泌腺；激素信号通过血液实现远距离调节。"
    },
    {
      "id": "med.anat.immune",
      "name_zh": "免疫系统",
      "name_en": "Immune System",
      "depth_level": "K11",
      "prerequisites": ["med.anat.body_system_overview", "med.anat.cardiovascular"],
      "description": "骨髓、胸腺、脾、淋巴结、淋巴管；先天与适应性免疫，B 细胞抗体与 T 细胞杀伤的分工。"
    },
    {
      "id": "med.anat.muscle_skeleton",
      "name_zh": "肌骨系统",
      "name_en": "Musculoskeletal System",
      "depth_level": "K7",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "骨骼分类、关节类型、骨骼肌/平滑肌/心肌的差别；肌肉拉动骨骼产生运动的杠杆原理。"
    },
    {
      "id": "med.phys.heart_rate",
      "name_zh": "心率",
      "name_en": "Heart Rate",
      "depth_level": "K7",
      "prerequisites": ["med.anat.cardiovascular"],
      "description": "心率的正常范围、测量方法（脉搏/智能手表）；静息心率、运动心率、最大心率与年龄的关系。"
    },
    {
      "id": "med.phys.blood_pressure",
      "name_zh": "血压",
      "name_en": "Blood Pressure",
      "depth_level": "K9",
      "prerequisites": ["med.anat.cardiovascular", "med.phys.heart_rate"],
      "description": "收缩压/舒张压的产生机理；袖带测量原理、单位 mmHg；高血压/低血压的分级与健康影响。"
    },
    {
      "id": "med.phys.oxygen_saturation",
      "name_zh": "血氧饱和度",
      "name_en": "Oxygen Saturation",
      "depth_level": "K9",
      "prerequisites": ["med.anat.respiratory", "med.anat.cardiovascular"],
      "description": "SpO2 含义：血红蛋白与氧结合比例；脉搏血氧仪的红外原理；高原反应与肺部疾病的判读。"
    },
    {
      "id": "med.phys.body_temp",
      "name_zh": "体温",
      "name_en": "Body Temperature",
      "depth_level": "K5",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "正常体温与昼夜节律、个体差异；下丘脑的体温调定点；发热的生理意义与测量部位差异。"
    },
    {
      "id": "med.phys.hormone",
      "name_zh": "激素调节",
      "name_en": "Hormone Regulation",
      "depth_level": "K11",
      "prerequisites": ["med.anat.endocrine"],
      "description": "胰岛素/胰高血糖素调节血糖、甲状腺素调节代谢、肾上腺素应激响应；负反馈环路的通用框架。"
    },
    {
      "id": "med.phys.stress_response",
      "name_zh": "应激反应",
      "name_en": "Stress Response",
      "depth_level": "K11",
      "prerequisites": ["med.anat.nervous", "med.anat.endocrine", "med.phys.hormone"],
      "description": "战或逃反应：交感神经激活、肾上腺素与皮质醇释放；急性应激与慢性应激对健康的不同影响。"
    },
    {
      "id": "med.path.infection",
      "name_zh": "感染",
      "name_en": "Infection",
      "depth_level": "K7",
      "prerequisites": ["med.anat.immune"],
      "description": "病原体（细菌、病毒、真菌、寄生虫）入侵机体；传染源、传播途径、易感人群三要素。"
    },
    {
      "id": "med.path.inflammation",
      "name_zh": "炎症",
      "name_en": "Inflammation",
      "depth_level": "K9",
      "prerequisites": ["med.anat.immune", "med.path.infection"],
      "description": "红、肿、热、痛、功能障碍五大体征；急性炎症 vs 慢性炎症；炎症既保护又可能致病的双面性。"
    },
    {
      "id": "med.path.cancer",
      "name_zh": "癌症",
      "name_en": "Cancer",
      "depth_level": "K11",
      "prerequisites": ["med.anat.immune"],
      "description": "细胞失控增殖、原癌基因/抑癌基因突变；良性 vs 恶性肿瘤、转移机制；常见癌种与早筛意义。"
    },
    {
      "id": "med.path.chronic_disease",
      "name_zh": "慢性病",
      "name_en": "Chronic Disease",
      "depth_level": "K9",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "高血压、糖尿病、心脑血管、慢阻肺等常见慢性病；病程长、致残率高、与生活方式紧密相关。"
    },
    {
      "id": "med.path.drug_resistance",
      "name_zh": "耐药性",
      "name_en": "Drug Resistance",
      "depth_level": "K11",
      "prerequisites": ["med.path.infection"],
      "description": "抗生素滥用导致细菌进化出耐药机制；超级细菌（MRSA）案例；合理用药与抗生素管理。"
    },
    {
      "id": "med.epi.basic",
      "name_zh": "流行病学基础",
      "name_en": "Epidemiology Basics",
      "depth_level": "K9",
      "prerequisites": ["med.path.infection"],
      "description": "发病率、患病率、死亡率、病死率四类核心指标；队列研究与病例对照研究的基本设计。"
    },
    {
      "id": "med.epi.r0",
      "name_zh": "基本传染数 R0",
      "name_en": "Basic Reproduction Number R0",
      "depth_level": "K11",
      "prerequisites": ["med.epi.basic"],
      "description": "R0 含义：一名感染者在完全易感人群中平均传染的人数；R0>1 流行扩大，<1 衰减；不同传染病的 R0 比较。"
    },
    {
      "id": "med.epi.vaccination",
      "name_zh": "疫苗",
      "name_en": "Vaccination",
      "depth_level": "K7",
      "prerequisites": ["med.anat.immune"],
      "description": "疫苗原理：用减毒/灭活/亚单位/mRNA 抗原训练免疫记忆；接种程序与群体免疫概念。"
    },
    {
      "id": "med.epi.public_health",
      "name_zh": "公共卫生",
      "name_en": "Public Health",
      "depth_level": "K9",
      "prerequisites": ["med.epi.basic"],
      "description": "公共卫生关注人群健康：饮水安全、疫苗接种、卫生宣教、疾病监测、慢病防控的系统性工作。"
    },
    {
      "id": "med.epi.outbreak",
      "name_zh": "疫情爆发",
      "name_en": "Disease Outbreak",
      "depth_level": "K11",
      "prerequisites": ["med.epi.basic", "med.epi.r0", "med.epi.public_health"],
      "description": "本地爆发、地方流行、大流行的分级；溯源调查、隔离检疫、接触者追踪、口罩与社交距离等干预措施。"
    },
    {
      "id": "med.lifestyle.nutrition",
      "name_zh": "营养基础",
      "name_en": "Nutrition Basics",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "六大营养素：糖类、脂肪、蛋白质、维生素、矿物质、水；膳食金字塔与均衡饮食的基本原则。"
    },
    {
      "id": "med.lifestyle.exercise",
      "name_zh": "运动健康",
      "name_en": "Exercise and Health",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "有氧运动 vs 力量训练；每周推荐运动量；运动对心肺、肌肉、情绪、免疫的多方面益处。"
    },
    {
      "id": "med.lifestyle.sleep",
      "name_zh": "睡眠",
      "name_en": "Sleep",
      "depth_level": "K7",
      "prerequisites": ["med.anat.nervous"],
      "description": "睡眠周期（REM 与非 REM 各阶段）；不同年龄段的睡眠需求；睡眠不足对记忆、免疫、情绪的影响。"
    },
    {
      "id": "med.diag.symptom",
      "name_zh": "症状识别",
      "name_en": "Symptom Recognition",
      "depth_level": "K7",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "发热、咳嗽、胸痛、腹痛、头痛等常见症状的可能病因与就医信号；何时该急诊、何时可观察。"
    },
    {
      "id": "med.diag.blood_test",
      "name_zh": "血检",
      "name_en": "Blood Test",
      "depth_level": "K9",
      "prerequisites": ["med.anat.cardiovascular", "med.anat.immune"],
      "description": "血常规（红细胞、白细胞、血小板）、肝肾功能、血糖血脂常见指标的临床意义与正常范围。"
    },
    {
      "id": "med.diag.imaging",
      "name_zh": "医学影像",
      "name_en": "Medical Imaging",
      "depth_level": "K11",
      "prerequisites": ["med.anat.body_system_overview"],
      "description": "X 光（骨骼）、CT（断层）、MRI（软组织）、超声（实时动态）四类影像的成像原理、辐射差异与适用场景。"
    }
  ]
}
