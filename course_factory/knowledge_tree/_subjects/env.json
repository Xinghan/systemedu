{
  "id": "env",
  "name_zh": "环境",
  "name_en": "Environmental Science",
  "color": "#67B07F",
  "nodes": [
    {
      "id": "env.atm.composition",
      "name_zh": "大气成分",
      "name_en": "Atmospheric Composition",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "地球大气主要成分：氮气 78%、氧气 21%、氩 1%，以及二氧化碳、水汽等微量气体的作用。"
    },
    {
      "id": "env.atm.layer",
      "name_zh": "大气分层",
      "name_en": "Atmospheric Layers",
      "depth_level": "K7",
      "prerequisites": ["env.atm.composition"],
      "description": "对流层、平流层、中间层、热层、外层的高度范围与温度变化；天气发生于对流层，臭氧层位于平流层。"
    },
    {
      "id": "env.atm.pressure_temp",
      "name_zh": "气压与温度",
      "name_en": "Pressure and Temperature",
      "depth_level": "K7",
      "prerequisites": ["env.atm.composition"],
      "description": "大气压随高度递减；气温随高度变化规律；气压计与温度计原理；高低压系统对天气的影响。"
    },
    {
      "id": "env.atm.humidity",
      "name_zh": "湿度",
      "name_en": "Humidity",
      "depth_level": "K7",
      "prerequisites": ["env.atm.composition"],
      "description": "绝对湿度、相对湿度、露点温度的定义；水汽饱和与凝结；湿度对人体舒适度与天气的影响。"
    },
    {
      "id": "env.atm.boundary_layer",
      "name_zh": "大气边界层",
      "name_en": "Atmospheric Boundary Layer",
      "depth_level": "K11",
      "prerequisites": ["env.atm.layer", "env.atm.pressure_temp"],
      "description": "近地面 1-2 km 受地表摩擦与热通量影响的大气层；日间混合层与夜间稳定层；逆温层对污染物扩散的抑制作用。"
    },
    {
      "id": "env.atm.circulation",
      "name_zh": "大气环流",
      "name_en": "Atmospheric Circulation",
      "depth_level": "K9",
      "prerequisites": ["env.atm.pressure_temp"],
      "description": "三圈环流（哈得来、费雷尔、极地环流）；信风、西风带；科里奥利效应对风向的影响。"
    },
    {
      "id": "env.climate.season",
      "name_zh": "季节",
      "name_en": "Seasons",
      "depth_level": "K3",
      "prerequisites": [],
      "description": "地球公转与地轴倾斜产生四季；不同纬度日照时长与太阳高度角的变化。"
    },
    {
      "id": "env.climate.weather_vs_climate",
      "name_zh": "天气 vs 气候",
      "name_en": "Weather vs Climate",
      "depth_level": "K5",
      "prerequisites": ["env.climate.season"],
      "description": "天气是短时大气状态（小时-天），气候是长期统计（30 年平均）；气候带划分（热带、温带、寒带）。"
    },
    {
      "id": "env.climate.water_cycle",
      "name_zh": "水循环",
      "name_en": "Water Cycle",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "蒸发、凝结、降水、径流、渗透六大过程；太阳能驱动水在海陆空之间循环。"
    },
    {
      "id": "env.climate.greenhouse_effect",
      "name_zh": "温室效应",
      "name_en": "Greenhouse Effect",
      "depth_level": "K7",
      "prerequisites": ["env.atm.composition"],
      "description": "温室气体（CO2、CH4、H2O）吸收地表长波辐射使地球升温；天然温室效应维持宜居温度，人为加剧导致升温。"
    },
    {
      "id": "env.climate.carbon_cycle",
      "name_zh": "碳循环",
      "name_en": "Carbon Cycle",
      "depth_level": "K9",
      "prerequisites": ["env.climate.greenhouse_effect"],
      "description": "碳在大气、海洋、生物圈、岩石圈之间的循环；光合作用与呼吸、化石燃料燃烧、海洋溶解的碳通量。"
    },
    {
      "id": "env.climate.climate_change",
      "name_zh": "气候变化",
      "name_en": "Climate Change",
      "depth_level": "K9",
      "prerequisites": ["env.climate.greenhouse_effect", "env.climate.weather_vs_climate"],
      "description": "工业革命以来全球平均气温上升；IPCC 报告与 1.5°C 目标；极端天气、冰川消融、海平面上升的连锁效应。"
    },
    {
      "id": "env.air.pollutant_types",
      "name_zh": "空气污染物分类",
      "name_en": "Air Pollutant Types",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "六大常规污染物：颗粒物（PM）、二氧化硫、氮氧化物、一氧化碳、臭氧、铅；一次污染物 vs 二次污染物。"
    },
    {
      "id": "env.air.pm25_pm10",
      "name_zh": "PM2.5 与 PM10",
      "name_en": "PM2.5 and PM10",
      "depth_level": "K7",
      "prerequisites": ["env.air.pollutant_types"],
      "description": "颗粒物按空气动力学直径分级：PM10（≤10μm）可入呼吸道，PM2.5（≤2.5μm）可入肺泡进入血液；来源（燃烧、扬尘、二次生成）。"
    },
    {
      "id": "env.air.aqi",
      "name_zh": "空气质量指数 AQI",
      "name_en": "Air Quality Index",
      "depth_level": "K7",
      "prerequisites": ["env.air.pm25_pm10", "env.air.pollutant_types"],
      "description": "AQI 把多种污染物浓度归一到 0-500 的统一指数；分段函数计算；不同国家标准差异（中国 GB3095 vs 美国 EPA）。"
    },
    {
      "id": "env.air.epa_standard",
      "name_zh": "EPA 标准 6 级",
      "name_en": "EPA AQI 6 Categories",
      "depth_level": "K9",
      "prerequisites": ["env.air.aqi"],
      "description": "美国 EPA 把 AQI 分为优(0-50)、良(51-100)、对敏感人群不健康(101-150)、不健康(151-200)、很不健康(201-300)、危险(301-500) 六级与对应颜色码。"
    },
    {
      "id": "env.air.health_impact",
      "name_zh": "健康影响",
      "name_en": "Health Impact of Air Pollution",
      "depth_level": "K9",
      "prerequisites": ["env.air.pm25_pm10"],
      "description": "短期暴露引发哮喘、心血管事件；长期暴露增加肺癌、心脏病、痴呆风险；敏感人群（儿童、老人、孕妇、哮喘患者）的额外防护。"
    },
    {
      "id": "env.air.source_attribution",
      "name_zh": "污染溯源",
      "name_en": "Source Attribution",
      "depth_level": "K11",
      "prerequisites": ["env.air.pm25_pm10", "env.atm.boundary_layer"],
      "description": "通过化学指纹、稳定同位素、受体模型（CMB、PMF）识别 PM 来源占比；本地排放 vs 区域传输的判别。"
    },
    {
      "id": "env.ocean.basic",
      "name_zh": "海洋基础",
      "name_en": "Ocean Basics",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "四大洋分布；海水盐度、温度、密度的基本概念；海洋覆盖地球 71% 表面。"
    },
    {
      "id": "env.ocean.current",
      "name_zh": "洋流",
      "name_en": "Ocean Currents",
      "depth_level": "K9",
      "prerequisites": ["env.ocean.basic", "env.atm.circulation"],
      "description": "表层洋流由风驱动（黑潮、湾流、加利福尼亚流）；深层洋流由温盐环流驱动；洋流对气候与渔业的影响。"
    },
    {
      "id": "env.ocean.coral_reef",
      "name_zh": "珊瑚礁",
      "name_en": "Coral Reefs",
      "depth_level": "K9",
      "prerequisites": ["env.ocean.basic"],
      "description": "珊瑚虫与虫黄藻的共生关系；珊瑚礁生态系统的生物多样性；白化现象的成因与全球大堡礁危机。"
    },
    {
      "id": "env.ocean.acidification",
      "name_zh": "海洋酸化",
      "name_en": "Ocean Acidification",
      "depth_level": "K11",
      "prerequisites": ["env.climate.carbon_cycle", "env.ocean.basic"],
      "description": "大气 CO2 溶入海水生成碳酸使 pH 下降（工业革命前 8.2 → 现今 8.1）；对贝类、珊瑚钙化与海洋食物网的威胁。"
    },
    {
      "id": "env.eco.forest",
      "name_zh": "森林生态",
      "name_en": "Forest Ecosystems",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "热带雨林、温带阔叶林、北方针叶林的分布与特征；森林的固碳、涵养水源、生物栖息地功能。"
    },
    {
      "id": "env.eco.biome",
      "name_zh": "生物群落",
      "name_en": "Biomes",
      "depth_level": "K7",
      "prerequisites": ["env.eco.forest", "env.climate.weather_vs_climate"],
      "description": "陆地主要生物群落（雨林、草原、沙漠、苔原、稀树草原）按温度-降水矩阵划分；Whittaker 气候分类图。"
    },
    {
      "id": "env.eco.wetland",
      "name_zh": "湿地",
      "name_en": "Wetlands",
      "depth_level": "K7",
      "prerequisites": ["env.climate.water_cycle"],
      "description": "沼泽、湿草甸、红树林、泥炭地的类型；湿地的净化水质、调蓄洪水、碳汇与候鸟栖息功能；拉姆萨公约保护。"
    },
    {
      "id": "env.eco.urban",
      "name_zh": "城市生态",
      "name_en": "Urban Ecology",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "城市作为生态系统：热岛效应、不透水面、城市绿地、雨水管理；人类活动对城市生物（鸟类、昆虫）的影响。"
    },
    {
      "id": "env.eco.biodiversity_threat",
      "name_zh": "生物多样性威胁",
      "name_en": "Biodiversity Threats",
      "depth_level": "K9",
      "prerequisites": ["env.eco.biome"],
      "description": "栖息地丧失、外来入侵种、过度捕捞、污染、气候变化五大威胁；IUCN 红色名录与第六次大灭绝事件证据。"
    },
    {
      "id": "env.sus.recycling",
      "name_zh": "回收",
      "name_en": "Recycling",
      "depth_level": "K3",
      "prerequisites": [],
      "description": "可回收物分类（纸、塑料、玻璃、金属）；垃圾分类的意义；3R 原则（Reduce、Reuse、Recycle）。"
    },
    {
      "id": "env.sus.renewable_energy",
      "name_zh": "可再生能源",
      "name_en": "Renewable Energy",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "太阳能、风能、水能、地热、生物质五大可再生能源；与化石能源的对比；储能与电网整合挑战。"
    },
    {
      "id": "env.sus.un_sdg",
      "name_zh": "联合国可持续发展目标",
      "name_en": "UN Sustainable Development Goals",
      "depth_level": "K9",
      "prerequisites": [],
      "description": "联合国 2030 议程 17 个 SDG，涵盖消除贫困、清洁水、可负担能源、气候行动等；指标体系与国家进度评估。"
    },
    {
      "id": "env.sus.lifecycle",
      "name_zh": "生命周期分析",
      "name_en": "Life Cycle Assessment",
      "depth_level": "K11",
      "prerequisites": ["env.sus.renewable_energy"],
      "description": "LCA 方法学：从原料、生产、使用到废弃的全周期环境影响评估；ISO 14040 标准；产品碳足迹计算。"
    },
    {
      "id": "env.mon.citizen_science",
      "name_zh": "公民科学",
      "name_en": "Citizen Science",
      "depth_level": "K7",
      "prerequisites": [],
      "description": "公众参与科学数据采集（鸟类计数、水质监测、空气质量观测）；典型项目（eBird、iNaturalist、PurpleAir）；数据质量与开放共享。"
    },
    {
      "id": "env.mon.remote_sensing",
      "name_zh": "遥感",
      "name_en": "Remote Sensing",
      "depth_level": "K11",
      "prerequisites": [],
      "description": "卫星、航空、无人机平台对地观测；可见光、红外、雷达波段；植被指数 NDVI、地表温度、大气 NO2 反演的环境应用。"
    },
    {
      "id": "env.mon.iot_sensor_network",
      "name_zh": "物联网传感网",
      "name_en": "IoT Sensor Networks",
      "depth_level": "K11",
      "prerequisites": ["env.mon.citizen_science"],
      "description": "低成本传感器 + WiFi/LoRa/NB-IoT 通信 + 云端聚合的环境监测架构；时间同步、数据校准、节点失效处理的工程问题。"
    },
    {
      "id": "env.mon.purpleair_network",
      "name_zh": "PurpleAir 全球网络",
      "name_en": "PurpleAir Global Network",
      "depth_level": "K9",
      "prerequisites": ["env.mon.citizen_science", "env.air.pm25_pm10"],
      "description": "PurpleAir 由全球 3 万+ 公民部署的 PM2.5 传感节点组成；激光散射原理 + 双传感冗余；公开 API + 实时地图；与 EPA 监测站的差异与校准。"
    }
  ]
}
