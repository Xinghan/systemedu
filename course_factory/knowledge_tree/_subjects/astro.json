{
  "id": "astro",
  "name_zh": "天文",
  "name_en": "Astronomy",
  "color": "#9B7BD8",
  "nodes": [
    {
      "id": "astro.solar.sun_basic",
      "name_zh": "太阳基础",
      "name_en": "The Sun Basics",
      "depth_level": "K3",
      "prerequisites": [],
      "description": "认识太阳是离地球最近的恒星，是发光发热的气体球，为地球提供光与能量，理解昼夜与四季的能量源头。"
    },
    {
      "id": "astro.solar.planets",
      "name_zh": "八大行星",
      "name_en": "Eight Planets",
      "depth_level": "K3",
      "prerequisites": ["astro.solar.sun_basic"],
      "description": "认识太阳系八大行星的顺序、相对大小与基本特征，区分类地行星与气态巨行星。"
    },
    {
      "id": "astro.solar.moon_phase",
      "name_zh": "月相",
      "name_en": "Moon Phases",
      "depth_level": "K5",
      "prerequisites": ["astro.solar.sun_basic"],
      "description": "理解月相变化是月球绕地公转中被太阳照亮部分相对地球的几何投影，掌握新月、上弦、满月、下弦四相周期约 29.5 天。"
    },
    {
      "id": "astro.solar.eclipse",
      "name_zh": "日食月食",
      "name_en": "Solar and Lunar Eclipse",
      "depth_level": "K5",
      "prerequisites": ["astro.solar.moon_phase"],
      "description": "理解日食是月球挡住太阳、月食是地球阴影遮住月球，掌握三球共线的几何条件与本影、半影区别。"
    },
    {
      "id": "astro.solar.asteroid_comet",
      "name_zh": "小行星与彗星",
      "name_en": "Asteroids and Comets",
      "depth_level": "K7",
      "prerequisites": ["astro.solar.planets"],
      "description": "认识小行星带、柯伊伯带与奥尔特云分布，理解彗星的彗核、彗发与彗尾结构及其太阳风成因。"
    },
    {
      "id": "astro.solar.formation",
      "name_zh": "太阳系形成",
      "name_en": "Solar System Formation",
      "depth_level": "K9",
      "prerequisites": ["astro.solar.planets", "astro.solar.asteroid_comet"],
      "description": "理解星云假说：原始气体云因引力坍缩形成原行星盘，盘内吸积形成太阳与各行星，解释行星轨道共面与同向公转。"
    },
    {
      "id": "astro.solar.kepler_law",
      "name_zh": "开普勒定律",
      "name_en": "Kepler's Laws",
      "depth_level": "K11",
      "prerequisites": ["astro.solar.planets"],
      "description": "掌握开普勒三定律：椭圆轨道、面积速度守恒、周期平方正比于半长轴立方 T²∝a³，理解行星运动的数学规律。"
    },
    {
      "id": "astro.solar.exoplanet",
      "name_zh": "系外行星",
      "name_en": "Exoplanets",
      "depth_level": "K11",
      "prerequisites": ["astro.solar.planets", "astro.solar.kepler_law"],
      "description": "理解凌星法、视向速度法等系外行星探测原理，认识宜居带概念与开普勒、TESS 任务成果。"
    },
    {
      "id": "astro.star.constellation",
      "name_zh": "星座",
      "name_en": "Constellations",
      "depth_level": "K3",
      "prerequisites": [],
      "description": "认识星空中按古人想象划分的 88 星座，掌握北斗七星指北极星方法及四季典型星座（猎户、天蝎、天鹅、仙后）。"
    },
    {
      "id": "astro.star.light_year",
      "name_zh": "光年与距离",
      "name_en": "Light Year and Distance",
      "depth_level": "K7",
      "prerequisites": ["astro.star.constellation"],
      "description": "理解光年是光在真空中一年行进的距离（约 9.46 万亿公里），建立宇宙尺度直觉，区分光年（距离）与年（时间）。"
    },
    {
      "id": "astro.star.color_temp",
      "name_zh": "恒星颜色与温度",
      "name_en": "Stellar Color and Temperature",
      "depth_level": "K9",
      "prerequisites": ["astro.star.light_year"],
      "description": "理解黑体辐射使恒星颜色反映表面温度：红冷蓝热，掌握 OBAFGKM 光谱分类与赫罗图横轴含义。"
    },
    {
      "id": "astro.star.lifecycle",
      "name_zh": "恒星演化",
      "name_en": "Stellar Evolution",
      "depth_level": "K11",
      "prerequisites": ["astro.star.color_temp"],
      "description": "理解恒星从分子云塌缩、主序氢燃烧、红巨星到白矮星或中子星的完整生命周期，掌握赫罗图上演化轨迹。"
    },
    {
      "id": "astro.star.supernova",
      "name_zh": "超新星",
      "name_en": "Supernova",
      "depth_level": "K11",
      "prerequisites": ["astro.star.lifecycle"],
      "description": "理解大质量恒星核心铁堆积后引力坍缩引发的爆炸，区分 Ia 型（白矮星吸积）与 II 型（核坍缩），认识超新星抛射重元素的宇宙化学意义。"
    },
    {
      "id": "astro.star.black_hole",
      "name_zh": "黑洞",
      "name_en": "Black Hole",
      "depth_level": "K11",
      "prerequisites": ["astro.star.supernova"],
      "description": "理解大质量恒星坍缩或星系中心形成的引力极强天体，掌握事件视界、史瓦西半径概念与 EHT 拍摄的 M87 黑洞图像。"
    },
    {
      "id": "astro.galaxy.milky_way",
      "name_zh": "银河系",
      "name_en": "The Milky Way",
      "depth_level": "K7",
      "prerequisites": ["astro.star.light_year"],
      "description": "认识银河系是包含数千亿恒星的棒旋星系，直径约 10 万光年，太阳位于猎户臂距中心约 2.6 万光年处。"
    },
    {
      "id": "astro.galaxy.types",
      "name_zh": "星系分类",
      "name_en": "Galaxy Types",
      "depth_level": "K11",
      "prerequisites": ["astro.galaxy.milky_way"],
      "description": "掌握哈勃星系分类音叉图：椭圆星系、旋涡星系（含棒旋）、不规则星系，理解形态与恒星形成活动的关系。"
    },
    {
      "id": "astro.galaxy.local_group",
      "name_zh": "本星系群",
      "name_en": "Local Group",
      "depth_level": "K11",
      "prerequisites": ["astro.galaxy.milky_way"],
      "description": "认识以银河系与仙女座星系为主、横跨约 1000 万光年的本星系群结构，理解仙女座 40 亿年后将与银河系碰撞合并。"
    },
    {
      "id": "astro.galaxy.dark_matter",
      "name_zh": "暗物质",
      "name_en": "Dark Matter",
      "depth_level": "K13",
      "prerequisites": ["astro.galaxy.types"],
      "description": "理解星系旋转曲线异常与引力透镜效应揭示的不可见质量，认识暗物质占宇宙物质约 85% 但与电磁波不耦合。"
    },
    {
      "id": "astro.cosmo.big_bang",
      "name_zh": "宇宙大爆炸",
      "name_en": "Big Bang",
      "depth_level": "K9",
      "prerequisites": ["astro.galaxy.milky_way"],
      "description": "理解宇宙起源于约 138 亿年前一个炽热致密的奇点，经暴胀、核合成、复合等阶段演化至今，掌握三大观测证据概念。"
    },
    {
      "id": "astro.cosmo.expansion",
      "name_zh": "宇宙膨胀",
      "name_en": "Cosmic Expansion",
      "depth_level": "K11",
      "prerequisites": ["astro.cosmo.big_bang", "astro.tool.spectroscopy"],
      "description": "理解哈勃定律 v = H₀·d：星系退行速度正比于距离，红移揭示空间本身在膨胀，掌握哈勃常数当前测值约 70 km/s/Mpc。"
    },
    {
      "id": "astro.cosmo.cmb",
      "name_zh": "宇宙背景辐射",
      "name_en": "Cosmic Microwave Background",
      "depth_level": "K13",
      "prerequisites": ["astro.cosmo.big_bang"],
      "description": "理解 CMB 是宇宙复合期约 38 万年时光子退耦留下的 2.725K 黑体辐射，掌握 COBE/WMAP/Planck 各向异性图谱与早期宇宙信息。"
    },
    {
      "id": "astro.cosmo.dark_energy",
      "name_zh": "暗能量",
      "name_en": "Dark Energy",
      "depth_level": "K13",
      "prerequisites": ["astro.cosmo.expansion"],
      "description": "理解 Ia 型超新星观测揭示的宇宙加速膨胀，认识暗能量占宇宙总能量约 68% 且具有负压性质，与宇宙学常数 Λ 关联。"
    },
    {
      "id": "astro.tool.telescope",
      "name_zh": "望远镜",
      "name_en": "Telescope",
      "depth_level": "K5",
      "prerequisites": [],
      "description": "认识折射式与反射式望远镜的成像原理，理解口径决定集光能力与分辨率，区分地面与空间望远镜（哈勃、JWST）观测优势。"
    },
    {
      "id": "astro.tool.spectroscopy",
      "name_zh": "光谱学",
      "name_en": "Spectroscopy",
      "depth_level": "K11",
      "prerequisites": ["astro.tool.telescope"],
      "description": "理解恒星光谱中的吸收/发射线对应元素特征，掌握多普勒红移/蓝移测速原理与光谱分析在天体成分、温度、运动中的应用。"
    },
    {
      "id": "astro.tool.parallax",
      "name_zh": "视差测距",
      "name_en": "Parallax Distance",
      "depth_level": "K11",
      "prerequisites": ["astro.tool.telescope"],
      "description": "理解利用地球公转两端观测恒星角位移测距：1 秒差距 ≈ 3.26 光年，掌握 Gaia 任务对近邻恒星的精确测距方法。"
    }
  ]
}
